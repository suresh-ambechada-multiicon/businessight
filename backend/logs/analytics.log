{"timestamp": "2026-05-04 09:10:08,358", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "df7167c8744d", "session_id": "1777885635728", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    service,\n    CASE \n        WHEN status IN ('Confirmed', 'Success', 'Payment Completed', 'Payment Confirmed', 'Completed') THEN 'Confirmed'\n        WHEN status IN ('Cancelled', 'Partial Cancelled', 'Partially Cancelled', 'Rejected', 'Documents Rejected') THEN 'Cancelled'\n        WHEN status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'Inprocess', 'Applied', 'Confirmation Pending', 'Hold', 'New', 'Documents Revised') THEN 'Pending'\n        WHEN status IN ('Refunded', 'Assign To Refund') THEN 'Refunded'\n        WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed') THEN 'Failed'\n        ELSE 'Other'\n    END as category,\n    COUNT(*) as count\nFROM (\n    SELECT 'Air' as service, booking_status as status FROM air_booking\n    UNION ALL\n    SELECT 'Bus' as service, status as status FROM bus_booking\n    UNION ALL\n    SELECT 'Hotel' as service, booking_status as status FROM hotel_booking\n    UNION ALL\n    SELECT 'Insurance' as service, booking_status as status FROM insurance_booking\n    UNION ALL\n    SELECT 'Visa' as service, visa_status as status FROM visa_booking\n    UNION ALL\n    SELECT 'Offline' as service, status as status FROM offline_service_booking\n) as all_bookings\nGROUP BY service, category\nORDER BY service, count DESC;", "rows_returned": 27, "truncated": false, "execution_time_ms": 41.91, "query_index": 3}
{"timestamp": "2026-05-04 09:10:11,243", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "df7167c8744d", "session_id": "1777885635728", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT fail_reason, COUNT(*) as count \nFROM air_booking \nWHERE booking_status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed')\nGROUP BY fail_reason \nORDER BY count DESC \nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 231.86, "query_index": 4}
{"timestamp": "2026-05-04 09:10:16,475", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "df7167c8744d", "session_id": "1777885635728", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    service,\n    ROUND(100.0 * SUM(CASE WHEN category = 'Confirmed' THEN 1 ELSE 0 END) / COUNT(*), 2) as efficiency_rate,\n    SUM(CASE WHEN category = 'Pending' THEN 1 ELSE 0 END) as pending_count,\n    SUM(CASE WHEN category = 'Failed' THEN 1 ELSE 0 END) as failed_count,\n    SUM(CASE WHEN category = 'Cancelled' THEN 1 ELSE 0 END) as cancelled_count,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT \n        service,\n        CASE \n            WHEN status IN ('Confirmed', 'Success', 'Payment Completed', 'Payment Confirmed', 'Completed') THEN 'Confirmed'\n            WHEN status IN ('Cancelled', 'Partial Cancelled', 'Partially Cancelled', 'Rejected', 'Documents Rejected') THEN 'Cancelled'\n            WHEN status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'Inprocess', 'Applied', 'Confirmation Pending', 'Hold', 'New', 'Documents Revised') THEN 'Pending'\n            WHEN status IN ('Refunded', 'Assign To Refund') THEN 'Refunded'\n            WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed') THEN 'Failed'\n            ELSE 'Other'\n        END as category\n    FROM (\n        SELECT 'Air' as service, booking_status as status FROM air_booking\n        UNION ALL\n        SELECT 'Bus' as service, status as status FROM bus_booking\n        UNION ALL\n        SELECT 'Hotel' as service, booking_status as status FROM hotel_booking\n        UNION ALL\n        SELECT 'Insurance' as service, booking_status as status FROM insurance_booking\n        UNION ALL\n        SELECT 'Visa' as service, visa_status as status FROM visa_booking\n        UNION ALL\n        SELECT 'Offline' as service, status as status FROM offline_service_booking\n    ) as all_bookings\n) as categorized\nGROUP BY service\nORDER BY efficiency_rate DESC;", "rows_returned": 6, "truncated": false, "execution_time_ms": 60.86, "query_index": 5}
{"timestamp": "2026-05-04 09:10:21,120", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "df7167c8744d", "session_id": "1777885635728", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(entry_date_time, 'YYYY-MM') as month,\n    COUNT(*) as total_bookings,\n    SUM(CASE WHEN category = 'Confirmed' THEN 1 ELSE 0 END) as confirmed,\n    SUM(CASE WHEN category = 'Failed' THEN 1 ELSE 0 END) as failed,\n    SUM(CASE WHEN category = 'Pending' THEN 1 ELSE 0 END) as pending\nFROM (\n    SELECT \n        entry_date_time,\n        CASE \n            WHEN status IN ('Confirmed', 'Success', 'Payment Completed', 'Payment Confirmed', 'Completed') THEN 'Confirmed'\n            WHEN status IN ('Cancelled', 'Partial Cancelled', 'Partially Cancelled', 'Rejected', 'Documents Rejected') THEN 'Cancelled'\n            WHEN status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'Inprocess', 'Applied', 'Confirmation Pending', 'Hold', 'New', 'Documents Revised') THEN 'Pending'\n            WHEN status IN ('Refunded', 'Assign To Refund') THEN 'Refunded'\n            WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed') THEN 'Failed'\n            ELSE 'Other'\n        END as category\n    FROM (\n        SELECT entry_date_time, booking_status as status FROM air_booking\n        UNION ALL\n        SELECT entry_date_time, status as status FROM bus_booking\n        UNION ALL\n        SELECT entry_date_time, booking_status as status FROM hotel_booking\n        UNION ALL\n        SELECT entry_date_time, booking_status as status FROM insurance_booking\n        UNION ALL\n        SELECT entry_date_time, visa_status as status FROM visa_booking\n        UNION ALL\n        SELECT entry_date_time, status as status FROM offline_service_booking\n    ) as all_bookings\n) as categorized\nWHERE entry_date_time >= '2024-01-01'\nGROUP BY month\nORDER BY month;", "rows_returned": 26, "truncated": false, "execution_time_ms": 109.74, "query_index": 6}
{"timestamp": "2026-05-04 09:10:24,637", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "df7167c8744d", "session_id": "1777885635728", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    booking_service,\n    COUNT(*) as total_entries,\n    SUM(CASE WHEN refunded_amount > 0 THEN 1 ELSE 0 END) as entries_with_refund,\n    SUM(refunded_amount) as total_refunded_amount\nFROM booking_price\nGROUP BY booking_service;", "rows_returned": 12, "truncated": false, "execution_time_ms": 159.65, "query_index": 7}
