{"timestamp": "2026-05-04 09:13:33,386", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77f9ed100a3b", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT 'Air' as type, booking_status as status, count(*) FROM air_booking GROUP BY booking_status\nUNION ALL\nSELECT 'Bus' as type, status as status, count(*) FROM bus_booking GROUP BY status\nUNION ALL\nSELECT 'Hotel' as type, booking_status as status, count(*) FROM hotel_booking GROUP BY booking_status\nUNION ALL\nSELECT 'Insurance' as type, booking_status as status, count(*) FROM insurance_booking GROUP BY booking_status\nUNION ALL\nSELECT 'Visa' as type, visa_status as status, count(*) FROM visa_booking GROUP BY visa_status\nUNION ALL\nSELECT 'Offline' as type, status as status, count(*) FROM offline_service_booking GROUP BY status;", "rows_returned": 56, "truncated": false, "execution_time_ms": 19.92, "query_index": 1}
{"timestamp": "2026-05-04 09:13:41,849", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77f9ed100a3b", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    CASE \n        WHEN status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n        WHEN status IN ('Cancelled', 'Partial Cancelled', 'Partially Cancelled', 'Rejected', 'Documents Rejected') THEN 'Cancelled'\n        WHEN status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'New', 'Applied', 'Inprocess', 'Confirmation Pending', 'Hold', 'Documents Revised') THEN 'Pending'\n        WHEN status IN ('Refunded', 'Assign To Refund') THEN 'Refunded'\n        WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed') THEN 'Failed'\n        ELSE 'Other'\n    END as category,\n    count(*) as count\nFROM (\n    SELECT booking_status as status FROM air_booking\n    UNION ALL\n    SELECT status as status FROM bus_booking\n    UNION ALL\n    SELECT booking_status as status FROM hotel_booking\n    UNION ALL\n    SELECT booking_status as status FROM insurance_booking\n    UNION ALL\n    SELECT visa_status as status FROM visa_booking\n    UNION ALL\n    SELECT status as status FROM offline_service_booking\n) as all_bookings\nGROUP BY category\nORDER BY count DESC;", "rows_returned": 6, "truncated": false, "execution_time_ms": 27.27, "query_index": 2}
{"timestamp": "2026-05-04 09:13:44,860", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77f9ed100a3b", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    type,\n    CASE \n        WHEN status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n        WHEN status IN ('Cancelled', 'Partial Cancelled', 'Partially Cancelled', 'Rejected', 'Documents Rejected') THEN 'Cancelled'\n        WHEN status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'New', 'Applied', 'Inprocess', 'Confirmation Pending', 'Hold', 'Documents Revised') THEN 'Pending'\n        WHEN status IN ('Refunded', 'Assign To Refund') THEN 'Refunded'\n        WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed') THEN 'Failed'\n        ELSE 'Other'\n    END as category,\n    count(*) as count\nFROM (\n    SELECT 'Air' as type, booking_status as status FROM air_booking\n    UNION ALL\n    SELECT 'Bus' as type, status as status FROM bus_booking\n    UNION ALL\n    SELECT 'Hotel' as type, booking_status as status FROM hotel_booking\n    UNION ALL\n    SELECT 'Insurance' as type, booking_status as status FROM insurance_booking\n    UNION ALL\n    SELECT 'Visa' as type, visa_status as status FROM visa_booking\n    UNION ALL\n    SELECT 'Offline' as type, status as status FROM offline_service_booking\n) as all_bookings\nGROUP BY type, category\nORDER BY type, count DESC;", "rows_returned": 27, "truncated": false, "execution_time_ms": 59.27, "query_index": 3}
{"timestamp": "2026-05-04 09:13:47,865", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77f9ed100a3b", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT 'Air' as type, fail_reason, count(*) FROM air_booking WHERE booking_status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed') GROUP BY fail_reason ORDER BY count DESC LIMIT 5;", "rows_returned": 5, "truncated": false, "execution_time_ms": 73.08, "query_index": 4}
{"timestamp": "2026-05-04 09:13:49,605", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77f9ed100a3b", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT 'Hotel' as type, fail_reason, count(*) FROM hotel_booking WHERE booking_status IN ('Booking Failed', 'Payment Failed', 'Failed') GROUP BY fail_reason ORDER BY count DESC LIMIT 5;", "rows_returned": 5, "truncated": false, "execution_time_ms": 10.28, "query_index": 5}
{"timestamp": "2026-05-04 09:13:51,836", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77f9ed100a3b", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    EXTRACT(YEAR FROM entry_date_time) as year,\n    EXTRACT(MONTH FROM entry_date_time) as month,\n    count(*) \nFROM visa_booking \nWHERE visa_status = 'Pending' \nGROUP BY year, month \nORDER BY year DESC, month DESC \nLIMIT 12;", "rows_returned": 12, "truncated": false, "execution_time_ms": 31.49, "query_index": 6}
{"timestamp": "2026-05-04 09:13:56,270", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77f9ed100a3b", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    type,\n    SUM(CASE WHEN category = 'Confirmed' THEN count ELSE 0 END) as confirmed,\n    SUM(CASE WHEN category = 'Failed' THEN count ELSE 0 END) as failed,\n    SUM(CASE WHEN category = 'Pending' THEN count ELSE 0 END) as pending,\n    SUM(CASE WHEN category = 'Cancelled' THEN count ELSE 0 END) as cancelled,\n    SUM(CASE WHEN category = 'Refunded' THEN count ELSE 0 END) as refunded\nFROM (\n    SELECT \n        type,\n        CASE \n            WHEN status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n            WHEN status IN ('Cancelled', 'Partial Cancelled', 'Partially Cancelled', 'Rejected', 'Documents Rejected') THEN 'Cancelled'\n            WHEN status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'New', 'Applied', 'Inprocess', 'Confirmation Pending', 'Hold', 'Documents Revised') THEN 'Pending'\n            WHEN status IN ('Refunded', 'Assign To Refund') THEN 'Refunded'\n            WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed') THEN 'Failed'\n            ELSE 'Other'\n        END as category,\n        count(*) as count\n    FROM (\n        SELECT 'Air' as type, booking_status as status FROM air_booking\n        UNION ALL\n        SELECT 'Bus' as type, status as status FROM bus_booking\n        UNION ALL\n        SELECT 'Hotel' as type, booking_status as status FROM hotel_booking\n        UNION ALL\n        SELECT 'Insurance' as type, booking_status as status FROM insurance_booking\n        UNION ALL\n        SELECT 'Visa' as type, visa_status as status FROM visa_booking\n        UNION ALL\n        SELECT 'Offline' as type, status as status FROM offline_service_booking\n    ) as all_bookings\n    GROUP BY type, category\n) as grouped_data\nGROUP BY type\nORDER BY confirmed DESC;", "rows_returned": 6, "truncated": false, "execution_time_ms": 59.18, "query_index": 7}
