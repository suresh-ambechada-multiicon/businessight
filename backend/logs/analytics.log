{"timestamp": "2026-05-04 13:29:38,477", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "95ae132c8138", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(entry_date_time, 'YYYY-MM') as month,\n    SUM(net_sale_amount) as monthly_revenue\nFROM booking_price\nWHERE booking_service IN ('Airline', 'Air Amendment') \n  AND is_deleted = false\n  AND entry_date_time >= CURRENT_DATE - INTERVAL '12 months'\nGROUP BY month\nORDER BY month ASC", "rows_returned": 11, "truncated": false, "execution_time_ms": 205.22, "query_index": 7}
