{"timestamp": "2026-05-05 11:09:25,957", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "1c5f03268a38", "session_id": "1777979356478", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 1000 s.company_name, COUNT(a.id) AS booking_count\nFROM supplier_master s\nJOIN air_booking a ON s.id = a.supplier_id\nWHERE a.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY s.company_name\nUNION ALL\nSELECT TOP 1000 s.company_name, COUNT(h.id) AS booking_count\nFROM supplier_master s\nJOIN hotel_booking h ON s.id = h.supplier_id\nWHERE h.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY s.company_name\nUNION ALL\nSELECT TOP 1000 s.company_name, COUNT(b.id) AS booking_count\nFROM supplier_master s\nJOIN bus_booking b ON s.id = b.supplier_id\nWHERE b.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY s.company_name", "rows_returned": 21, "truncated": false, "execution_time_ms": 978.4, "query_index": 1}
{"timestamp": "2026-05-05 11:09:28,772", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "1c5f03268a38", "session_id": "1777979356478", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT s.company_name, SUM(booking_count) AS total_bookings\nFROM (\n    SELECT supplier_id, COUNT(*) AS booking_count FROM air_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM hotel_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM bus_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n) AS combined_bookings\nJOIN supplier_master s ON combined_bookings.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_bookings DESC", "rows_returned": 21, "truncated": false, "execution_time_ms": 1088.14, "query_index": 2}
{"timestamp": "2026-05-05 11:09:31,589", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "1c5f03268a38", "session_id": "1777979356478", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 20 s.company_name, SUM(booking_count) AS total_bookings\nFROM (\n    SELECT supplier_id, COUNT(*) AS booking_count FROM air_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM hotel_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM bus_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n) AS combined_bookings\nJOIN supplier_master s ON combined_bookings.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_bookings DESC", "rows_returned": 20, "truncated": false, "execution_time_ms": 1065.89, "query_index": 3}
