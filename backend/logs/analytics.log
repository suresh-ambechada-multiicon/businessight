{"timestamp": "2026-05-04 09:38:27,919", "level": "INFO", "logger": "analytics.tools", "message": "Tool: get_table_info", "request_id": "c7cfd5b93cdf", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "tables": "insurance_booking, holiday_booking_leads", "time_ms": 16.04}
{"timestamp": "2026-05-04 09:38:31,803", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "c7cfd5b93cdf", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT fail_reason, COUNT(*) as count, 'Air' as category FROM air_booking WHERE fail_reason IS NOT NULL AND fail_reason != '' GROUP BY fail_reason\nUNION ALL\nSELECT fail_reason, COUNT(*) as count, 'Hotel' as category FROM hotel_booking WHERE fail_reason IS NOT NULL AND fail_reason != '' GROUP BY fail_reason\nUNION ALL\nSELECT payment_fail_reason as fail_reason, COUNT(*) as count, 'Visa' as category FROM visa_booking WHERE payment_fail_reason IS NOT NULL AND payment_fail_reason != '' GROUP BY payment_fail_reason\nUNION ALL\nSELECT fail_reason, COUNT(*) as count, 'Insurance' as category FROM insurance_booking WHERE fail_reason IS NOT NULL AND fail_reason != '' GROUP BY fail_reason\nORDER BY count DESC LIMIT 20;", "rows_returned": 20, "truncated": false, "execution_time_ms": 276.23, "query_index": 1}
{"timestamp": "2026-05-04 09:38:41,333", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "c7cfd5b93cdf", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    CASE \n        WHEN fail_reason ILIKE '%Payment%not done%' OR fail_reason ILIKE '%Payment failed%' OR fail_reason ILIKE '%Payment Gateway Fail%' OR fail_reason ILIKE '%Add Payment Failed%' THEN 'Payment/Agent Issue'\n        WHEN fail_reason ILIKE '%character limit exceeded%' OR fail_reason ILIKE '%Invalid%' THEN 'Data Entry/Agent Issue'\n        WHEN fail_reason ILIKE '%TraceId%expired%' OR fail_reason ILIKE '%Ticketing process failed%' OR fail_reason ILIKE '%ABORTED%' OR fail_reason ILIKE '%Supplier Res%' OR fail_reason ILIKE '%no response%' OR fail_reason ILIKE '%Airline Genral Error%' OR fail_reason ILIKE '%Unable to sell%' THEN 'Technical/Supplier Issue'\n        ELSE 'Other/Unknown'\n    END as issue_type,\n    COUNT(*) as total_count\nFROM (\n    SELECT fail_reason FROM air_booking WHERE fail_reason IS NOT NULL AND fail_reason != '' AND fail_reason != 'SUCCESS'\n    UNION ALL\n    SELECT fail_reason FROM hotel_booking WHERE fail_reason IS NOT NULL AND fail_reason != ''\n    UNION ALL\n    SELECT payment_fail_reason as fail_reason FROM visa_booking WHERE payment_fail_reason IS NOT NULL AND payment_fail_reason != ''\n    UNION ALL\n    SELECT fail_reason FROM insurance_booking WHERE fail_reason IS NOT NULL AND fail_reason != ''\n) as all_fails\nGROUP BY 1\nORDER BY 2 DESC;", "rows_returned": 4, "truncated": false, "execution_time_ms": 121.1, "query_index": 2}
{"timestamp": "2026-05-04 09:38:46,376", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "c7cfd5b93cdf", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    issue_type,\n    fail_reason,\n    count\nFROM (\n    SELECT \n        CASE \n            WHEN fail_reason ILIKE '%Payment%not done%' OR fail_reason ILIKE '%Payment failed%' OR fail_reason ILIKE '%Payment Gateway Fail%' OR fail_reason ILIKE '%Add Payment Failed%' THEN 'Payment/Agent Issue'\n            WHEN fail_reason ILIKE '%character limit exceeded%' OR fail_reason ILIKE '%Invalid%' THEN 'Data Entry/Agent Issue'\n            WHEN fail_reason ILIKE '%TraceId%expired%' OR fail_reason ILIKE '%Ticketing process failed%' OR fail_reason ILIKE '%ABORTED%' OR fail_reason ILIKE '%Supplier Res%' OR fail_reason ILIKE '%no response%' OR fail_reason ILIKE '%Airline Genral Error%' OR fail_reason ILIKE '%Unable to sell%' THEN 'Technical/Supplier Issue'\n            ELSE 'Other/Unknown'\n        END as issue_type,\n        fail_reason,\n        COUNT(*) as count,\n        ROW_NUMBER() OVER(PARTITION BY \n            CASE \n                WHEN fail_reason ILIKE '%Payment%not done%' OR fail_reason ILIKE '%Payment failed%' OR fail_reason ILIKE '%Payment Gateway Fail%' OR fail_reason ILIKE '%Add Payment Failed%' THEN 'Payment/Agent Issue'\n                WHEN fail_reason ILIKE '%character limit exceeded%' OR fail_reason ILIKE '%Invalid%' THEN 'Data Entry/Agent Issue'\n                WHEN fail_reason ILIKE '%TraceId%expired%' OR fail_reason ILIKE '%Ticketing process failed%' OR fail_reason ILIKE '%ABORTED%' OR fail_reason ILIKE '%Supplier Res%' OR fail_reason ILIKE '%no response%' OR fail_reason ILIKE '%Airline Genral Error%' OR fail_reason ILIKE '%Unable to sell%' THEN 'Technical/Supplier Issue'\n                ELSE 'Other/Unknown'\n            END \n            ORDER BY COUNT(*) DESC) as rank\n    FROM (\n        SELECT fail_reason FROM air_booking WHERE fail_reason IS NOT NULL AND fail_reason != '' AND fail_reason != 'SUCCESS'\n        UNION ALL\n        SELECT fail_reason FROM hotel_booking WHERE fail_reason IS NOT NULL AND fail_reason != ''\n        UNION ALL\n        SELECT payment_fail_reason as fail_reason FROM visa_booking WHERE payment_fail_reason IS NOT NULL AND payment_fail_reason != ''\n        UNION ALL\n        SELECT fail_reason FROM insurance_booking WHERE fail_reason IS NOT NULL AND fail_reason != ''\n    ) as all_fails\n    GROUP BY 1, 2\n) as ranked_fails\nWHERE rank <= 5\nORDER BY issue_type, count DESC;", "rows_returned": 20, "truncated": false, "execution_time_ms": 128.78, "query_index": 3}
