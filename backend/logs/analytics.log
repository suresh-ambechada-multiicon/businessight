{"timestamp": "2026-05-05 10:20:29,303", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "0527c54d907d", "session_id": "1777976151159", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-pro-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 1000\n    sm.company_name AS provider_name,\n    COUNT(b.id) AS number_of_bookings\nFROM supplier_master sm\nJOIN (\n    SELECT id, supplier_id, entry_date_time FROM air_booking WHERE is_deleted = 0 OR is_deleted IS NULL\n    UNION ALL\n    SELECT id, supplier_id, entry_date_time FROM bus_booking WHERE is_deleted = 0 OR is_deleted IS NULL\n    UNION ALL\n    SELECT id, supplier_id, entry_date_time FROM hotel_booking WHERE is_deleted = 0 OR is_deleted IS NULL\n    UNION ALL\n    SELECT id, supplier_id, entry_date_time FROM insurance_booking WHERE is_deleted = 0 OR is_deleted IS NULL\n) b ON sm.id = b.supplier_id\nWHERE b.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY sm.company_name\nORDER BY number_of_bookings DESC", "rows_returned": 23, "truncated": false, "execution_time_ms": 2800.02, "query_index": 1}
