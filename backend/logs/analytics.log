{"timestamp": "2026-05-05 09:52:05,261", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "f7c352fbcc2d", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-pro-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT hm.hotel_name, ht.single_sharing, ht.double_sharing, ht.triple_sharing, ht.from_date, ht.to_date\nFROM hotel_tariff ht\nJOIN hotel_master hm ON ht.hotel_id = hm.id\nORDER BY GREATEST(COALESCE(ht.single_sharing, 0), COALESCE(ht.double_sharing, 0), COALESCE(ht.triple_sharing, 0)) DESC\nLIMIT 10;", "rows_returned": 0, "truncated": false, "execution_time_ms": 27.32, "query_index": 1}
{"timestamp": "2026-05-05 09:52:08,994", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "f7c352fbcc2d", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-pro-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT COUNT(*) FROM hotel_tariff;", "rows_returned": 1, "truncated": false, "execution_time_ms": 1.68, "query_index": 2}
{"timestamp": "2026-05-05 09:52:13,311", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "f7c352fbcc2d", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-pro-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT hb.hotel_name, hbr.room_name, hbr.room_purchase_price, hb.check_in_date, hb.check_out_date, hb.no_of_rooms,\n       DATE_PART('day', hb.check_out_date::timestamp - hb.check_in_date::timestamp) as nights\nFROM hotel_booking hb\nJOIN hotel_booking_rooms hbr ON hb.id = hbr.hotel_booking_id\nWHERE hb.booking_status = 'Confirmed'\nORDER BY hbr.room_purchase_price DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 32.06, "query_index": 3}
{"timestamp": "2026-05-05 09:52:21,393", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "f7c352fbcc2d", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-pro-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT hb.hotel_name, hbr.room_name, hbr.room_purchase_price, hb.check_in_date, hb.check_out_date, \n       DATE_PART('day', hb.check_out_date::timestamp - hb.check_in_date::timestamp) as nights,\n       (hbr.room_purchase_price / NULLIF(DATE_PART('day', hb.check_out_date::timestamp - hb.check_in_date::timestamp), 0)) as cost_per_night\nFROM hotel_booking hb\nJOIN hotel_booking_rooms hbr ON hb.id = hbr.hotel_booking_id\nWHERE hb.booking_status = 'Confirmed'\n  AND DATE_PART('day', hb.check_out_date::timestamp - hb.check_in_date::timestamp) > 0\nORDER BY cost_per_night DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 6.56, "query_index": 4}
