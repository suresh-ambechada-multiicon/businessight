{"timestamp": "2026-05-06 18:27:58,774", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "16478554dd7f", "session_id": "1778092059920", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    'Air' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= '2026-01-16'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Hotel' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= '2026-01-16'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Bus' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN bb.status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM bus_booking bb\nJOIN supplier_master sm ON bb.supplier_id = sm.id\nWHERE bb.entry_date_time >= '2026-01-16'\n  AND bb.is_deleted = false\nGROUP BY sm.company_name\n\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 5, "truncated": false, "execution_time_ms": 5.17, "query_index": 4}
{"timestamp": "2026-05-06 18:28:01,647", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "16478554dd7f", "session_id": "1778092059920", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Cancelled' THEN 1 ELSE 0 END) AS cancelled_bookings,\n    SUM(CASE WHEN ab.booking_status NOT IN ('Confirmed', 'Cancelled') THEN 1 ELSE 0 END) AS other_status_bookings\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= '2026-01-16'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\nORDER BY total_bookings DESC;", "rows_returned": 4, "truncated": false, "execution_time_ms": 2.07, "query_index": 5}
