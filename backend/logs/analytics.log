{"timestamp": "2026-05-06 19:39:59,636", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75511a18bf6a", "session_id": "1778096253455", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(CASE WHEN ab.service_type = 'Air' THEN 1 END) as air_bookings,\n    COUNT(CASE WHEN ab.service_type = 'Hotel' THEN 1 END) as hotel_bookings,\n    COUNT(CASE WHEN ab.service_type = 'Bus' THEN 1 END) as bus_bookings,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT supplier_id, 'Air' as service_type FROM air_booking \n    WHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months' AND booking_status = 'Confirmed' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, 'Hotel' as service_type FROM hotel_booking \n    WHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months' AND booking_status = 'Confirmed' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, 'Bus' as service_type FROM bus_booking \n    WHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months' AND status = 'Confirmed' AND is_deleted = false\n) ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 2, "truncated": false, "execution_time_ms": 1.77, "query_index": 1}
{"timestamp": "2026-05-06 19:40:03,353", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75511a18bf6a", "session_id": "1778096253455", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    'Air' as service,\n    MIN(entry_date_time) as min_date,\n    MAX(entry_date_time) as max_date,\n    COUNT(*) as total_confirmed\nFROM air_booking\nWHERE booking_status = 'Confirmed' AND is_deleted = false\nUNION ALL\nSELECT \n    'Hotel' as service,\n    MIN(entry_date_time) as min_date,\n    MAX(entry_date_time) as max_date,\n    COUNT(*) as total_confirmed\nFROM hotel_booking\nWHERE booking_status = 'Confirmed' AND is_deleted = false;", "rows_returned": 2, "truncated": false, "execution_time_ms": 35.55, "query_index": 2}
{"timestamp": "2026-05-06 19:40:06,025", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75511a18bf6a", "session_id": "1778096253455", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(CASE WHEN ab.service_type = 'Air' THEN 1 END) as air_bookings,\n    COUNT(CASE WHEN ab.service_type = 'Hotel' THEN 1 END) as hotel_bookings,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT supplier_id, 'Air' as service_type FROM air_booking \n    WHERE entry_date_time >= '2024-01-01' AND booking_status = 'Confirmed' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, 'Hotel' as service_type FROM hotel_booking \n    WHERE entry_date_time >= '2024-01-01' AND booking_status = 'Confirmed' AND is_deleted = false\n) ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 20;", "rows_returned": 20, "truncated": false, "execution_time_ms": 34.4, "query_index": 3}
{"timestamp": "2026-05-06 19:40:09,317", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75511a18bf6a", "session_id": "1778096253455", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(CASE WHEN ab.service_type = 'Air' THEN 1 END) as air_bookings,\n    COUNT(CASE WHEN ab.service_type = 'Hotel' THEN 1 END) as hotel_bookings,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT supplier_id, 'Air' as service_type FROM air_booking \n    WHERE entry_date_time >= '2024-04-01' AND booking_status = 'Confirmed' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, 'Hotel' as service_type FROM hotel_booking \n    WHERE entry_date_time >= '2024-04-01' AND booking_status = 'Confirmed' AND is_deleted = false\n) ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 20;", "rows_returned": 20, "truncated": false, "execution_time_ms": 37.32, "query_index": 4}
{"timestamp": "2026-05-06 19:40:12,240", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75511a18bf6a", "session_id": "1778096253455", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(entry_date_time, 'YYYY-MM') as month,\n    COUNT(*) as booking_count\nFROM air_booking\nWHERE entry_date_time >= '2024-01-01' AND booking_status = 'Confirmed' AND is_deleted = false\nGROUP BY 1\nORDER BY 1 DESC;", "rows_returned": 24, "truncated": false, "execution_time_ms": 85.26, "query_index": 5}
