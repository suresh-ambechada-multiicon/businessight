{"timestamp": "2026-05-05 12:09:34,376", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "c75e58ec511f", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    FORMAT(ab.entry_date_time, 'yyyy-MM') AS Month,\n    SUM(bp.net_sale_amount) AS Total_Amount,\n    COUNT(ab.id) AS Booking_Count\nFROM air_booking ab\nJOIN booking_price bp ON ab.id = bp.booking_id AND bp.booking_service = 'Air'\nWHERE ab.supplier_id = 23\n  AND ab.entry_date_time >= DATEADD(year, -1, GETDATE())\n  AND ab.booking_status = 'Success'\nGROUP BY FORMAT(ab.entry_date_time, 'yyyy-MM')\nORDER BY Month;", "rows_returned": 0, "truncated": false, "execution_time_ms": 19.16, "query_index": 1}
