{"timestamp": "2026-05-06 20:29:13,262", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "ef720b60dcf5", "session_id": "1778099330173", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    s.company_name AS supplier_name,\n    COUNT(b.id) AS total_bookings,\n    SUM(CASE WHEN b.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN b.booking_status = 'Cancelled' THEN 1 ELSE 0 END) AS cancelled_bookings\nFROM air_booking b\nJOIN supplier_master s ON b.supplier_id = s.id\nWHERE b.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND b.is_deleted = false\nGROUP BY s.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 2, "truncated": false, "execution_time_ms": 9.04, "query_index": 1}
{"timestamp": "2026-05-06 20:29:13,264", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "ef720b60dcf5", "session_id": "1778099330173", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    s.company_name AS supplier_name,\n    COUNT(b.id) AS total_bookings,\n    SUM(CASE WHEN b.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN b.booking_status = 'Cancelled' THEN 1 ELSE 0 END) AS cancelled_bookings\nFROM hotel_booking b\nJOIN supplier_master s ON b.supplier_id = s.id\nWHERE b.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND b.is_deleted = false\nGROUP BY s.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 1, "truncated": false, "execution_time_ms": 3.01, "query_index": 2}
