{"timestamp": "2026-05-06 20:21:20,387", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "c479433156d5", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    'Air' as service_type,\n    COUNT(*) as booking_count\nFROM air_booking ab\nJOIN supplier_wise_api swa ON ab.supplier_id = swa.id\nJOIN supplier_master sm ON swa.supplier_id = sm.id\nWHERE ab.booking_status = 'Confirmed'\n  AND ab.entry_date_time >= '2026-01-16'\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name as supplier_name,\n    'Bus' as service_type,\n    COUNT(*) as booking_count\nFROM bus_booking bb\nJOIN supplier_wise_api swa ON bb.supplier_id = swa.id\nJOIN supplier_master sm ON swa.supplier_id = sm.id\nWHERE bb.status = 'Confirmed'\n  AND bb.entry_date_time >= '2026-01-16'\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name as supplier_name,\n    'Hotel' as service_type,\n    COUNT(*) as booking_count\nFROM hotel_booking hb\nJOIN supplier_wise_api swa ON hb.supplier_id = swa.id\nJOIN supplier_master sm ON swa.supplier_id = sm.id\nWHERE hb.booking_status = 'Confirmed'\n  AND hb.entry_date_time >= '2026-01-16'\nGROUP BY sm.company_name\nORDER BY booking_count DESC;", "rows_returned": 4, "truncated": false, "execution_time_ms": 3.54, "query_index": 2}
{"timestamp": "2026-05-06 20:21:23,179", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "c479433156d5", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    DATE_TRUNC('month', entry_date_time) as booking_month,\n    COUNT(*) as total_bookings\nFROM air_booking\nWHERE booking_status = 'Confirmed'\n  AND entry_date_time >= '2025-10-01'\nGROUP BY 1\nORDER BY 1 DESC;", "rows_returned": 6, "truncated": false, "execution_time_ms": 20.31, "query_index": 3}
{"timestamp": "2026-05-06 20:21:26,536", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "c479433156d5", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT COUNT(*) FROM air_booking WHERE entry_date_time >= '2026-02-01' AND entry_date_time < '2026-03-01';", "rows_returned": 1, "truncated": false, "execution_time_ms": 1.24, "query_index": 4}
