{"timestamp": "2026-05-05 12:10:39,851", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75954082647c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 10\n    s.company_name,\n    COUNT(b.id) as total_bookings,\n    SUM(p.net_sale_amount) as total_revenue\nFROM (\n    SELECT id, supplier_id, 'Air' as service FROM air_booking WHERE booking_status IN ('Confirmed', 'Partially Cancelled', 'Refund Assigned')\n    UNION ALL\n    SELECT id, supplier_id, 'Hotel' as service FROM hotel_booking WHERE booking_status IN ('Confirmed', 'Partially Cancelled', 'Refund Assigned')\n) b\nJOIN booking_price p ON b.id = p.booking_id AND b.service = p.booking_service\nJOIN supplier_master s ON b.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_revenue DESC", "rows_returned": 3, "truncated": false, "execution_time_ms": 1859.14, "query_index": 1}
