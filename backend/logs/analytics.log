{"timestamp": "2026-05-05 12:13:33,429", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "ae31f9e925e6", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT DISTINCT booking_status FROM insurance_booking", "rows_returned": 10, "truncated": false, "execution_time_ms": 38.87, "query_index": 4}
{"timestamp": "2026-05-05 12:13:38,672", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "ae31f9e925e6", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    s.company_name,\n    SUM(cancelled_count) as total_cancelled\nFROM (\n    SELECT supplier_id, COUNT(*) as cancelled_count \n    FROM air_booking \n    WHERE booking_status IN ('Cancelled', 'Partially Cancelled')\n    GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cancelled_count \n    FROM hotel_booking \n    WHERE booking_status IN ('Cancelled', 'Partially Cancelled')\n    GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cancelled_count \n    FROM bus_booking \n    WHERE status IN ('Cancelled')\n    GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cancelled_count \n    FROM insurance_booking \n    WHERE booking_status IN ('Cancelled', 'Partial Cancelled')\n    GROUP BY supplier_id\n) as t\nJOIN supplier_master s ON t.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_cancelled DESC", "rows_returned": 21, "truncated": false, "execution_time_ms": 252.14, "query_index": 5}
{"timestamp": "2026-05-05 12:13:43,105", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "ae31f9e925e6", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    s.company_name,\n    service_type,\n    COUNT(*) as cancelled_count\nFROM (\n    SELECT supplier_id, 'Air' as service_type\n    FROM air_booking \n    WHERE booking_status IN ('Cancelled', 'Partially Cancelled')\n    UNION ALL\n    SELECT supplier_id, 'Hotel' as service_type\n    FROM hotel_booking \n    WHERE booking_status IN ('Cancelled', 'Partially Cancelled')\n    UNION ALL\n    SELECT supplier_id, 'Bus' as service_type\n    FROM bus_booking \n    WHERE status IN ('Cancelled')\n    UNION ALL\n    SELECT supplier_id, 'Insurance' as service_type\n    FROM insurance_booking \n    WHERE booking_status IN ('Cancelled', 'Partial Cancelled')\n) as t\nJOIN supplier_master s ON t.supplier_id = s.id\nGROUP BY s.company_name, service_type\nORDER BY s.company_name, cancelled_count DESC", "rows_returned": 21, "truncated": false, "execution_time_ms": 150.51, "query_index": 6}
