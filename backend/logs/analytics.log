{"timestamp": "2026-05-06 20:29:22,099", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "ef720b60dcf5", "session_id": "1778099330173", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    s.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN b.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN b.booking_status IN ('Cancelled', 'Booking Failed', 'Payment Failed', 'Rejected') THEN 1 ELSE 0 END) AS failed_or_cancelled,\n    ROUND(100.0 * SUM(CASE WHEN b.booking_status = 'Confirmed' THEN 1 ELSE 0 END) / NULLIF(COUNT(*), 0), 2) as success_rate_pct\nFROM (\n    SELECT supplier_id, booking_status, entry_date_time FROM air_booking WHERE is_deleted = false\n    UNION ALL\n    SELECT supplier_id, booking_status, entry_date_time FROM hotel_booking WHERE is_deleted = false\n    UNION ALL\n    SELECT supplier_id, status as booking_status, entry_date_time FROM bus_booking WHERE is_deleted = false\n) b\nJOIN supplier_master s ON b.supplier_id = s.id\nWHERE b.entry_date_time >= '2026-01-16'\nGROUP BY s.company_name\nORDER BY total_bookings DESC\nLIMIT 20;", "rows_returned": 5, "truncated": false, "execution_time_ms": 6.68, "query_index": 5}
