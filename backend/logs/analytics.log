{"timestamp": "2026-05-06 19:40:21,436", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75511a18bf6a", "session_id": "1778096253455", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    TO_CHAR(ab.entry_date_time, 'YYYY-MM') as month,\n    COUNT(*) as booking_count\nFROM (\n    SELECT supplier_id, entry_date_time FROM air_booking \n    WHERE entry_date_time >= '2025-11-01' AND booking_status = 'Confirmed' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, entry_date_time FROM hotel_booking \n    WHERE entry_date_time >= '2025-11-01' AND booking_status = 'Confirmed' AND is_deleted = false\n) ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE sm.company_name IN ('New Journey Tours & Travels', 'Next Tour & Travels', 'Fly24hrs_air', 'Tripjack_hotel_live', 'Namo Tour And Travels')\nGROUP BY 1, 2\nORDER BY 2, 3 DESC;", "rows_returned": 15, "truncated": false, "execution_time_ms": 21.64, "query_index": 8}
