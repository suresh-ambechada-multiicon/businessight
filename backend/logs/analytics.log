{"timestamp": "2026-05-06 19:10:32,639", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d0599b7520dc", "session_id": "1778094158284", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    'Air' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Hotel' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Bus' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN bb.status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM bus_booking bb\nJOIN supplier_master sm ON bb.supplier_id = sm.id\nWHERE bb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND bb.is_deleted = false\nGROUP BY sm.company_name\n\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 3, "truncated": false, "execution_time_ms": 4.49, "query_index": 1}
