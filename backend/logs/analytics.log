{"timestamp": "2026-05-04 12:00:50,909", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "74af4d60207f", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    module_name, \n    COUNT(*) as invoice_count, \n    SUM(grand_total) as total_revenue,\n    AVG(grand_total) as avg_invoice_value\nFROM invoice_master \nWHERE is_deleted = false\nGROUP BY module_name \nORDER BY total_revenue DESC \nLIMIT 1000;", "rows_returned": 13, "truncated": false, "execution_time_ms": 60.61, "query_index": 1}
{"timestamp": "2026-05-04 12:00:53,274", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "74af4d60207f", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(invoice_date, 'YYYY-MM') as month,\n    SUM(grand_total) as monthly_revenue\nFROM invoice_master \nWHERE is_deleted = false AND invoice_date IS NOT NULL\nGROUP BY month \nORDER BY month DESC \nLIMIT 12;", "rows_returned": 12, "truncated": false, "execution_time_ms": 69.32, "query_index": 2}
{"timestamp": "2026-05-04 12:00:55,484", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "74af4d60207f", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    SUM(sgst) as total_sgst,\n    SUM(cgst) as total_cgst,\n    SUM(igst) as total_igst,\n    SUM(service_fee) as total_service_fee,\n    SUM(commission) as total_commission\nFROM invoice_master \nWHERE is_deleted = false;", "rows_returned": 1, "truncated": false, "execution_time_ms": 20.27, "query_index": 3}
