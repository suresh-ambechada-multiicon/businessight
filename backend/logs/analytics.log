{"timestamp": "2026-05-06 19:52:25,546", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77c8e5f4e3ef", "session_id": "1778097126952", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(*) as total_bookings,\n    COUNT(*) FILTER (WHERE b.booking_status IN ('Confirmed', 'Payment Completed')) as confirmed_bookings,\n    COUNT(*) FILTER (WHERE b.booking_status IN ('Cancelled', 'Partially Cancelled')) as cancelled_bookings\nFROM (\n    SELECT supplier_id, entry_date_time, booking_status FROM air_booking WHERE entry_date_time >= '2026-01-16' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, entry_date_time, booking_status FROM hotel_booking WHERE entry_date_time >= '2026-01-16' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, entry_date_time, status as booking_status FROM bus_booking WHERE entry_date_time >= '2026-01-16' AND is_deleted = false\n) b\nJOIN supplier_master sm ON b.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 5, "truncated": false, "execution_time_ms": 1.98, "query_index": 3}
{"timestamp": "2026-05-06 19:52:28,456", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "77c8e5f4e3ef", "session_id": "1778097126952", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    b.service_type,\n    COUNT(*) as total_bookings,\n    COUNT(*) FILTER (WHERE b.booking_status IN ('Confirmed', 'Payment Completed')) as confirmed_bookings\nFROM (\n    SELECT supplier_id, entry_date_time, booking_status, 'Air' as service_type FROM air_booking WHERE entry_date_time >= '2026-01-16' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, entry_date_time, booking_status, 'Hotel' as service_type FROM hotel_booking WHERE entry_date_time >= '2026-01-16' AND is_deleted = false\n    UNION ALL\n    SELECT supplier_id, entry_date_time, status as booking_status, 'Bus' as service_type FROM bus_booking WHERE entry_date_time >= '2026-01-16' AND is_deleted = false\n) b\nJOIN supplier_master sm ON b.supplier_id = sm.id\nGROUP BY sm.company_name, b.service_type\nORDER BY total_bookings DESC;", "rows_returned": 5, "truncated": false, "execution_time_ms": 2.69, "query_index": 4}
