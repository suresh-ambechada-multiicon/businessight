{"timestamp": "2026-05-05 12:10:56,230", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75954082647c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT COUNT(*) FROM air_block_leads WHERE supplier_id = 23 AND lead_status = 'Confirmed'", "rows_returned": 1, "truncated": false, "execution_time_ms": 27.4, "query_index": 6}
{"timestamp": "2026-05-05 12:11:18,432", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75954082647c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 10\n    s.company_name,\n    COUNT(DISTINCT b.booking_id) as total_bookings,\n    SUM(b.net_sale_amount) as total_revenue\nFROM (\n    SELECT p.booking_id, p.net_sale_amount, a.supplier_id\n    FROM booking_price p\n    JOIN air_booking a ON p.booking_id = a.id AND p.booking_service = 'Airline'\n    WHERE a.booking_status IN ('Confirmed', 'Partially Cancelled', 'Refund Assigned')\n      AND p.price_for = 'Bonton'\n    \n    UNION ALL\n    \n    SELECT p.booking_id, p.net_sale_amount, h.supplier_id\n    FROM booking_price p\n    JOIN hotel_booking h ON p.booking_id = h.id AND p.booking_service = 'Hotel'\n    WHERE h.booking_status IN ('Confirmed', 'Partially Cancelled', 'Refund Assigned')\n      AND p.price_for = 'Bonton'\n      \n    UNION ALL\n    \n    SELECT p.booking_id, p.net_sale_amount, b.supplier_id\n    FROM booking_price p\n    JOIN bus_booking b ON p.booking_id = b.id AND p.booking_service = 'Bus'\n    WHERE b.status IN ('Confirmed', 'Partially Cancelled', 'Refund Assigned')\n      AND p.price_for = 'Bonton'\n) b\nJOIN supplier_master s ON b.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_revenue DESC", "rows_returned": 10, "truncated": false, "execution_time_ms": 16390.11, "query_index": 7}
{"timestamp": "2026-05-05 12:11:26,683", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75954082647c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT id, company_name FROM supplier_master WHERE company_name IN ('Fly24hrs_air', 'New Journey Tours & Travels', 'Tripjack_hotel_live', 'Airiq_air', 'Namo Tour And Travels')", "rows_returned": 6, "truncated": false, "execution_time_ms": 20.44, "query_index": 8}
{"timestamp": "2026-05-05 12:11:33,827", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "75954082647c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    s.company_name,\n    YEAR(p.entry_date_time) as yr,\n    MONTH(p.entry_date_time) as mnth,\n    SUM(p.net_sale_amount) as monthly_revenue\nFROM booking_price p\nJOIN (\n    SELECT id, supplier_id, 'Airline' as service FROM air_booking WHERE booking_status IN ('Confirmed', 'Partially Cancelled', 'Refund Assigned')\n    UNION ALL\n    SELECT id, supplier_id, 'Hotel' as service FROM hotel_booking WHERE booking_status IN ('Confirmed', 'Partially Cancelled', 'Refund Assigned')\n) b ON p.booking_id = b.id AND p.booking_service = b.service\nJOIN supplier_master s ON b.supplier_id = s.id\nWHERE s.id IN (18, 23, 28, 29, 32, 41)\n  AND p.price_for = 'Bonton'\n  AND p.entry_date_time >= '2024-01-01'\nGROUP BY s.company_name, YEAR(p.entry_date_time), MONTH(p.entry_date_time)\nORDER BY yr, mnth, s.company_name", "rows_returned": 110, "truncated": false, "execution_time_ms": 2823.2, "query_index": 9}
{"timestamp": "2026-05-05 12:11:43,378", "level": "INFO", "logger": "analytics.agent", "message": "Stream completed", "request_id": "75954082647c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "stream_time_ms": 75164.71, "content_length": 4123, "tool_args_length": 5151, "has_report": true}
