{"timestamp": "2026-05-04 09:15:23,254", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "88b3633a7e84", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(entry_date_time, 'YYYY-MM') as month,\n    SUM(CASE WHEN category = 'Confirmed' THEN 1 ELSE 0 END) as confirmed,\n    SUM(CASE WHEN category = 'Failed' THEN 1 ELSE 0 END) as failed\nFROM (\n    SELECT \n        entry_date_time,\n        CASE \n            WHEN booking_status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n            WHEN booking_status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed', 'Hold Released') THEN 'Failed'\n        END as category\n    FROM air_booking\n    UNION ALL\n    SELECT \n        entry_date_time,\n        CASE \n            WHEN status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n            WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed', 'Hold Released') THEN 'Failed'\n        END as category\n    FROM bus_booking\n    UNION ALL\n    SELECT \n        entry_date_time,\n        CASE \n            WHEN booking_status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n            WHEN booking_status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed', 'Hold Released') THEN 'Failed'\n        END as category\n    FROM hotel_booking\n) as combined\nWHERE entry_date_time >= CURRENT_DATE - INTERVAL '12 months'\nGROUP BY month\nORDER BY month;", "rows_returned": 11, "truncated": false, "execution_time_ms": 52.03, "query_index": 9}
