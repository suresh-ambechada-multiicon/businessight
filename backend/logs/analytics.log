{"timestamp": "2026-05-06 18:21:08,936", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "35a9c7d97fee", "session_id": "1778091621821", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT * FROM booking_price WHERE booking_id = (SELECT id FROM air_booking LIMIT 1) AND booking_service = 'Airline'", "rows_returned": 2, "truncated": false, "execution_time_ms": 5.87, "query_index": 3}
{"timestamp": "2026-05-06 18:21:24,060", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "35a9c7d97fee", "session_id": "1778091621821", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    ab.service_type,\n    COUNT(ab.booking_id) as booking_count,\n    SUM(bp.net_purchase) as total_cost\nFROM (\n    SELECT \n        supplier_id, \n        'Airline' as service_type,\n        id as booking_id,\n        entry_date_time\n    FROM air_booking\n    WHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT \n        supplier_id, \n        'Hotel' as service_type,\n        id as booking_id,\n        entry_date_time\n    FROM hotel_booking\n    WHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT \n        supplier_id, \n        'Bus' as service_type,\n        id as booking_id,\n        entry_date_time\n    FROM bus_booking\n    WHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND status = 'Confirmed'\n    UNION ALL\n    SELECT \n        supplier_id, \n        'Insurance' as service_type,\n        id as booking_id,\n        entry_date_time\n    FROM insurance_booking\n    WHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND booking_status = 'Confirmed'\n) ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nLEFT JOIN booking_price bp ON ab.booking_id = bp.booking_id \n    AND ab.service_type = bp.booking_service \n    AND bp.price_for = 'Bonton'\nGROUP BY sm.company_name, ab.service_type\nORDER BY booking_count DESC", "rows_returned": 3, "truncated": false, "execution_time_ms": 24.07, "query_index": 4}
{"timestamp": "2026-05-06 18:21:27,839", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "35a9c7d97fee", "session_id": "1778091621821", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    'Air' as service, COUNT(*) \nFROM air_booking \nWHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\nUNION ALL\nSELECT \n    'Hotel' as service, COUNT(*) \nFROM hotel_booking \nWHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\nUNION ALL\nSELECT \n    'Bus' as service, COUNT(*) \nFROM bus_booking \nWHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\nUNION ALL\nSELECT \n    'Insurance' as service, COUNT(*) \nFROM insurance_booking \nWHERE entry_date_time >= CURRENT_DATE - INTERVAL '3 months'", "rows_returned": 4, "truncated": false, "execution_time_ms": 7.82, "query_index": 5}
