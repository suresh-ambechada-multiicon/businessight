{"timestamp": "2026-05-06 20:33:08,500", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "4389047f9916", "session_id": "1778099330173", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    s.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN b.status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM (\n    SELECT supplier_id, booking_status AS status, entry_date_time FROM air_booking\n    UNION ALL\n    SELECT supplier_id, booking_status AS status, entry_date_time FROM hotel_booking\n    UNION ALL\n    SELECT supplier_id, status, entry_date_time FROM bus_booking\n) b\nJOIN supplier_master s ON b.supplier_id = s.id\nWHERE b.entry_date_time >= '2024-04-16'\nGROUP BY s.company_name\nORDER BY total_bookings DESC\nLIMIT 15;", "rows_returned": 15, "truncated": false, "execution_time_ms": 60.31, "query_index": 2}
