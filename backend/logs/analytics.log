{"timestamp": "2026-05-06 19:02:08,163", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "03fee04e5841", "session_id": "1778093779874", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    COUNT(ab.id) AS booking_count,\n    'Air' AS service_type\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND ab.booking_status = 'Confirmed'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    COUNT(hb.id) AS booking_count,\n    'Hotel' AS service_type\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND hb.booking_status = 'Confirmed'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    COUNT(bb.id) AS booking_count,\n    'Bus' AS service_type\nFROM bus_booking bb\nJOIN supplier_master sm ON bb.supplier_id = sm.id\nWHERE bb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND bb.status = 'Confirmed'\n  AND bb.is_deleted = false\nGROUP BY sm.company_name\n\nORDER BY booking_count DESC\nLIMIT 1000;", "rows_returned": 2, "truncated": false, "execution_time_ms": 5.91, "query_index": 1}
{"timestamp": "2026-05-06 19:02:10,119", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "03fee04e5841", "session_id": "1778093779874", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT MAX(entry_date_time) FROM air_booking;", "rows_returned": 1, "truncated": false, "execution_time_ms": 2.37, "query_index": 2}
