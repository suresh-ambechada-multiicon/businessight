{"timestamp": "2026-05-06 19:20:29,456", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "243c88c78ab4", "session_id": "1778095201814", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Payment Failed' THEN 1 ELSE 0 END) AS payment_failed,\n    SUM(CASE WHEN hb.booking_status NOT IN ('Confirmed', 'Payment Failed') THEN 1 ELSE 0 END) AS other_status\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= '2026-01-16'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\nORDER BY total_bookings DESC;", "rows_returned": 1, "truncated": false, "execution_time_ms": 1.08, "query_index": 6}
{"timestamp": "2026-05-06 19:20:32,572", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "243c88c78ab4", "session_id": "1778095201814", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    TO_CHAR(ab.entry_date_time, 'YYYY-MM') AS booking_month,\n    COUNT(*) AS booking_count\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= '2026-01-16'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name, booking_month\nORDER BY booking_month ASC, booking_count DESC;", "rows_returned": 6, "truncated": false, "execution_time_ms": 1.72, "query_index": 7}
{"timestamp": "2026-05-06 19:20:36,476", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "243c88c78ab4", "session_id": "1778095201814", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Payment Failed' THEN 1 ELSE 0 END) AS payment_failed,\n    SUM(CASE WHEN ab.booking_status = 'Cancelled' THEN 1 ELSE 0 END) AS cancelled,\n    SUM(CASE WHEN ab.booking_status NOT IN ('Confirmed', 'Payment Failed', 'Cancelled') THEN 1 ELSE 0 END) AS other_status\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= '2026-01-16'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Payment Failed' THEN 1 ELSE 0 END) AS payment_failed,\n    SUM(CASE WHEN hb.booking_status = 'Cancelled' THEN 1 ELSE 0 END) AS cancelled,\n    SUM(CASE WHEN hb.booking_status NOT IN ('Confirmed', 'Payment Failed', 'Cancelled') THEN 1 ELSE 0 END) AS other_status\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= '2026-01-16'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\n\nORDER BY total_bookings DESC;", "rows_returned": 5, "truncated": false, "execution_time_ms": 2.12, "query_index": 8}
