{"timestamp": "2026-05-04 12:02:10,891", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "48d10c73911a", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    im.invoive_no, \n    im.invoice_date, \n    im.agent_name, \n    im.customer_name, \n    im.total_amount, \n    im.grand_total, \n    ism.hotel_name, \n    ism.hotel_city, \n    ism.pax_name\nFROM invoice_master im\nJOIN invoice_sub_master ism ON im.id = ism.invoice_id\nWHERE im.module_name = 'Hotel' AND im.is_deleted = false\nORDER BY im.invoice_date DESC\nLIMIT 1000;", "rows_returned": 1000, "truncated": false, "execution_time_ms": 63.62, "query_index": 1}
{"timestamp": "2026-05-04 12:02:13,833", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "48d10c73911a", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    COUNT(*) as total_invoices,\n    SUM(grand_total) as total_revenue,\n    AVG(grand_total) as avg_invoice_value,\n    MIN(invoice_date) as earliest_invoice,\n    MAX(invoice_date) as latest_invoice\nFROM invoice_master \nWHERE module_name = 'Hotel' AND is_deleted = false;", "rows_returned": 1, "truncated": false, "execution_time_ms": 30.2, "query_index": 2}
