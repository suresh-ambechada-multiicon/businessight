{"timestamp": "2026-05-06 18:22:13,338", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "35a9c7d97fee", "session_id": "1778091621821", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    supplier_name,\n    service_type,\n    SUM(booking_count) as booking_count,\n    SUM(total_cost) as total_cost\nFROM (\n    SELECT \n        sm.company_name as supplier_name,\n        'Airline' as service_type,\n        COUNT(ab.id) as booking_count,\n        SUM(bp.net_purchase) as total_cost\n    FROM air_booking ab\n    JOIN supplier_master sm ON ab.supplier_id = sm.id\n    LEFT JOIN booking_price bp ON ab.id = bp.booking_id \n        AND bp.booking_service = 'Airline' \n        AND bp.price_for = 'Bonton'\n    WHERE ab.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND ab.booking_status = 'Confirmed'\n    GROUP BY sm.company_name\n    \n    UNION ALL\n    \n    SELECT \n        sm.company_name as supplier_name,\n        'Hotel' as service_type,\n        COUNT(hb.id) as booking_count,\n        SUM(bp.net_purchase) as total_cost\n    FROM hotel_booking hb\n    JOIN supplier_master sm ON hb.supplier_id = sm.id\n    LEFT JOIN booking_price bp ON hb.id = bp.booking_id \n        AND bp.booking_service = 'Hotel' \n        AND bp.price_for = 'Bonton'\n    WHERE hb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND hb.booking_status = 'Confirmed'\n    GROUP BY sm.company_name\n    \n    UNION ALL\n    \n    SELECT \n        sm.company_name as supplier_name,\n        'Bus' as service_type,\n        COUNT(bb.id) as booking_count,\n        SUM(bp.net_purchase) as total_cost\n    FROM bus_booking bb\n    JOIN supplier_master sm ON bb.supplier_id = sm.id\n    LEFT JOIN booking_price bp ON bb.id = bp.booking_id \n        AND bp.booking_service = 'Bus' \n        AND bp.price_for = 'Bonton'\n    WHERE bb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND bb.status = 'Confirmed'\n    GROUP BY sm.company_name\n    \n    UNION ALL\n    \n    SELECT \n        sm.company_name as supplier_name,\n        'Insurance' as service_type,\n        COUNT(ib.id) as booking_count,\n        SUM(bp.net_purchase) as total_cost\n    FROM insurance_booking ib\n    JOIN supplier_master sm ON ib.supplier_id = sm.id\n    LEFT JOIN booking_price bp ON ib.id = bp.booking_id \n        AND bp.booking_service = 'Insurance' \n        AND bp.price_for = 'Bonton'\n    WHERE ib.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND ib.booking_status = 'Confirmed'\n    GROUP BY sm.company_name\n    \n    UNION ALL\n    \n    SELECT \n        sm.company_name as supplier_name,\n        'Offline' as service_type,\n        COUNT(op.id) as booking_count,\n        SUM(op.purchase_amount) as total_cost\n    FROM osb_purchase op\n    JOIN offline_service_booking osb ON op.osb_id = osb.id\n    JOIN supplier_master sm ON op.supplier_id = sm.id\n    WHERE osb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n      AND osb.status != 'Cancelled'\n    GROUP BY sm.company_name\n) combined\nGROUP BY supplier_name, service_type\nORDER BY booking_count DESC, total_cost DESC", "rows_returned": 9, "truncated": false, "execution_time_ms": 22.91, "query_index": 11}
