{"timestamp": "2026-05-05 10:45:43,480", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "456a21b4b701", "session_id": "1777977166363", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT s.company_name, SUM(cnt) as total_bookings\nFROM (\n    SELECT supplier_id, COUNT(*) as cnt FROM air_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM hotel_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM bus_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM visa_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM insurance_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n) as combined\nJOIN supplier_master s ON combined.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_bookings DESC\nOFFSET 0 ROWS FETCH NEXT 1000 ROWS ONLY", "rows_returned": 30, "truncated": false, "execution_time_ms": 1168.18, "query_index": 11}
{"timestamp": "2026-05-05 10:45:46,295", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "456a21b4b701", "session_id": "1777977166363", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 20 s.company_name, SUM(cnt) as total_bookings\nFROM (\n    SELECT supplier_id, COUNT(*) as cnt FROM air_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM hotel_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM bus_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM visa_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) as cnt FROM insurance_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n) as combined\nJOIN supplier_master s ON combined.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_bookings DESC", "rows_returned": 20, "truncated": false, "execution_time_ms": 1153.36, "query_index": 12}
