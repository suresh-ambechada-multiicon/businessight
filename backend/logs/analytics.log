{"timestamp": "2026-05-02 06:54:19,281", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "9f367bc5d904", "session_id": "1777703767723", "client_ip": "127.0.0.1", "model": "google_genai:gemini-2.5-flash", "db_uri_hash": "34fd0c4055f9", "query": "SELECT\n  pfd.id AS flight_id,\n  cm_dep.city_name AS departure_city,\n  pfd.departure_date_time,\n  cm_arr.city_name AS arrival_city,\n  pfd.arrival_date_time,\n  pfd.trip_type,\n  pfd.cabin_baggage,\n  pfd.checkin_baggage\nFROM product_flight_details AS pfd\nJOIN city_master AS cm_dep\n  ON pfd.departure_city_id = cm_dep.id\nJOIN city_master AS cm_arr\n  ON pfd.arrival_city_id = cm_arr.id\nWHERE\n  cm_dep.city_name = 'Delhi' OR cm_arr.city_name = 'Delhi'\nLIMIT 100;", "rows_returned": 0, "truncated": false, "execution_time_ms": 2.57, "query_index": 11}
