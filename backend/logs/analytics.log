{"timestamp": "2026-05-04 09:35:38,558", "level": "INFO", "logger": "analytics.tools", "message": "Tool: get_table_info", "request_id": "02f2afbdf422", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "tables": "booking_price", "time_ms": 12.6}
{"timestamp": "2026-05-04 09:35:41,868", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "02f2afbdf422", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    booking_service, \n    SUM(net_sale_amount) as total_net_sale, \n    SUM(net_purchase) as total_net_purchase, \n    SUM(net_sale_amount - net_purchase) as total_net_profit,\n    AVG(total_markup) as avg_markup,\n    COUNT(*) as booking_count\nFROM booking_price \nWHERE is_deleted = false OR is_deleted IS NULL\nGROUP BY booking_service\nORDER BY total_net_profit DESC\nLIMIT 1000;", "rows_returned": 12, "truncated": false, "execution_time_ms": 186.09, "query_index": 1}
{"timestamp": "2026-05-04 09:35:45,362", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "02f2afbdf422", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(entry_date_time, 'YYYY-MM') as month,\n    booking_service,\n    SUM(net_sale_amount - net_purchase) as monthly_net_profit,\n    AVG(total_markup) as avg_markup\nFROM booking_price \nWHERE (is_deleted = false OR is_deleted IS NULL)\n  AND entry_date_time >= CURRENT_DATE - INTERVAL '12 months'\n  AND booking_service IN ('Airline', 'Hotel', 'Bus', 'Visa')\nGROUP BY month, booking_service\nORDER BY month ASC, booking_service ASC;", "rows_returned": 40, "truncated": false, "execution_time_ms": 253.45, "query_index": 2}
{"timestamp": "2026-05-04 09:35:54,201", "level": "INFO", "logger": "analytics.agent", "message": "Stream completed", "request_id": "02f2afbdf422", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "stream_time_ms": 18298.64, "content_length": 3456, "tool_args_length": 903, "has_report": true}
