{"timestamp": "2026-05-05 12:19:11,808", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "8c530763bd17", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    s.company_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN b.status IN ('Cancelled', 'Partially Cancelled', 'Partial Cancelled', 'Cancellation Pending') THEN 1 ELSE 0 END) AS cancelled_bookings,\n    CAST(SUM(CASE WHEN b.status IN ('Cancelled', 'Partially Cancelled', 'Partial Cancelled', 'Cancellation Pending') THEN 1 ELSE 0 END) * 100.0 / NULLIF(COUNT(*), 0) AS DECIMAL(10, 2)) AS cancellation_percentage\nFROM (\n    SELECT supplier_id, booking_status AS status FROM air_booking WHERE is_deleted = 0\n    UNION ALL\n    SELECT supplier_id, status FROM bus_booking WHERE is_deleted = 0\n    UNION ALL\n    SELECT supplier_id, booking_status AS status FROM hotel_booking WHERE is_deleted = 0\n    UNION ALL\n    SELECT supplier_id, booking_status AS status FROM insurance_booking WHERE is_deleted = 0\n) b\nJOIN supplier_master s ON b.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY cancellation_percentage DESC", "rows_returned": 30, "truncated": false, "execution_time_ms": 1096.79, "query_index": 5}
