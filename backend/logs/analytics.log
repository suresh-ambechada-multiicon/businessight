{"timestamp": "2026-05-06 20:12:15,704", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "74cbdeeb0363", "session_id": "1778098158635", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(*) as total_bookings,\n    SUM(CASE WHEN b.status IN ('Confirmed', 'Payment Completed', 'Partial Payment Completed') THEN 1 ELSE 0 END) as confirmed_bookings,\n    SUM(CASE WHEN b.status IN ('Payment Failed', 'Cancelled', 'Booking Failed', 'Rejected', 'Hold Released', 'Hold Failed', 'Failed') THEN 1 ELSE 0 END) as failed_cancelled_bookings,\n    SUM(CASE WHEN b.status NOT IN ('Confirmed', 'Payment Completed', 'Partial Payment Completed', 'Payment Failed', 'Cancelled', 'Booking Failed', 'Rejected', 'Hold Released', 'Hold Failed', 'Failed') OR b.status IS NULL THEN 1 ELSE 0 END) as other_bookings\nFROM (\n    SELECT supplier_id, booking_status as status, entry_date_time FROM air_booking WHERE entry_date_time >= '2025-04-16'\n    UNION ALL\n    SELECT supplier_id, status, entry_date_time FROM bus_booking WHERE entry_date_time >= '2025-04-16'\n    UNION ALL\n    SELECT supplier_id, booking_status as status, entry_date_time FROM hotel_booking WHERE entry_date_time >= '2025-04-16'\n) b\nJOIN supplier_wise_api swa ON b.supplier_id = swa.id\nJOIN supplier_master sm ON swa.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC;", "rows_returned": 16, "truncated": false, "execution_time_ms": 86.6, "query_index": 2}
