{"timestamp": "2026-05-05 11:52:16,342", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d8dec2370dcc", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    sm.company_name,\n    SUM(b.booking_count) AS total_bookings\nFROM supplier_master sm\nJOIN (\n    SELECT supplier_id, COUNT(*) AS booking_count\n    FROM air_booking\n    WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) AND is_deleted = 0\n    GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count\n    FROM bus_booking\n    WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) AND is_deleted = 0\n    GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count\n    FROM hotel_booking\n    WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) AND is_deleted = 0\n    GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count\n    FROM insurance_booking\n    WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) AND is_deleted = 0\n    GROUP BY supplier_id\n) b ON sm.id = b.supplier_id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC", "rows_returned": 23, "truncated": false, "execution_time_ms": 1073.98, "query_index": 1}
