{"timestamp": "2026-05-04 11:56:20,870", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "3f646f6b1c20", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT airline, COUNT(DISTINCT air_booking_id) as booking_count\nFROM air_segment\nWHERE airline IS NOT NULL AND airline != ''\nGROUP BY airline\nORDER BY booking_count DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 152.76, "query_index": 1}
{"timestamp": "2026-05-04 11:56:23,523", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "3f646f6b1c20", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT airline_code, COUNT(DISTINCT air_booking_id) as booking_count\nFROM air_segment\nWHERE airline_code IS NOT NULL AND airline_code != ''\nGROUP BY airline_code\nORDER BY booking_count DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 139.06, "query_index": 2}
{"timestamp": "2026-05-04 11:56:26,073", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "3f646f6b1c20", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT am.airline_name, COUNT(DISTINCT asg.air_booking_id) as booking_count\nFROM air_segment asg\nJOIN airline_master am ON asg.airline_code = am.short_code\nWHERE asg.airline_code IS NOT NULL AND asg.airline_code != ''\nGROUP BY am.airline_name\nORDER BY booking_count DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 148.7, "query_index": 3}
