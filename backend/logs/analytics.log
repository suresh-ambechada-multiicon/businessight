{"timestamp": "2026-05-06 19:50:35,137", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "9502d3199f68", "session_id": "1778097013239", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(*) as total_bookings,\n    SUM(CASE WHEN b.booking_status = 'Confirmed' THEN 1 ELSE 0 END) as confirmed_bookings,\n    SUM(CASE WHEN b.booking_status IN ('Cancelled', 'Partially Cancelled') THEN 1 ELSE 0 END) as cancelled_bookings\nFROM air_booking b\nLEFT JOIN supplier_master sm ON b.supplier_id = sm.id\nWHERE b.entry_date_time >= '2026-01-16' AND b.is_deleted = false\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 4, "truncated": false, "execution_time_ms": 3.94, "query_index": 2}
{"timestamp": "2026-05-06 19:50:37,877", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "9502d3199f68", "session_id": "1778097013239", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(*) as total_bookings,\n    SUM(CASE WHEN b.booking_status = 'Confirmed' THEN 1 ELSE 0 END) as confirmed_bookings,\n    SUM(CASE WHEN b.booking_status IN ('Cancelled', 'Partially Cancelled') THEN 1 ELSE 0 END) as cancelled_bookings\nFROM hotel_booking b\nLEFT JOIN supplier_master sm ON b.supplier_id = sm.id\nWHERE b.entry_date_time >= '2026-01-16' AND b.is_deleted = false\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 1, "truncated": false, "execution_time_ms": 3.93, "query_index": 3}
{"timestamp": "2026-05-06 19:50:40,165", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "9502d3199f68", "session_id": "1778097013239", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(*) as total_bookings,\n    SUM(CASE WHEN b.status = 'Confirmed' THEN 1 ELSE 0 END) as confirmed_bookings,\n    SUM(CASE WHEN b.status IN ('Cancelled', 'Partially Cancelled') THEN 1 ELSE 0 END) as cancelled_bookings\nFROM bus_booking b\nLEFT JOIN supplier_master sm ON b.supplier_id = sm.id\nWHERE b.entry_date_time >= '2026-01-16' AND b.is_deleted = false\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 0, "truncated": false, "execution_time_ms": 1.31, "query_index": 4}
{"timestamp": "2026-05-06 19:50:43,003", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "9502d3199f68", "session_id": "1778097013239", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    COALESCE(sm.company_name, 'Unknown') as supplier_name,\n    COUNT(*) as total_bookings,\n    SUM(CASE WHEN status = 'Confirmed' THEN 1 ELSE 0 END) as confirmed_bookings,\n    SUM(CASE WHEN status IN ('Cancelled', 'Partially Cancelled') THEN 1 ELSE 0 END) as cancelled_bookings\nFROM (\n    SELECT supplier_id, booking_status as status, entry_date_time, is_deleted FROM air_booking\n    UNION ALL\n    SELECT supplier_id, booking_status as status, entry_date_time, is_deleted FROM hotel_booking\n    UNION ALL\n    SELECT supplier_id, status, entry_date_time, is_deleted FROM bus_booking\n) b\nLEFT JOIN supplier_master sm ON b.supplier_id = sm.id\nWHERE b.entry_date_time >= '2026-01-16' AND b.is_deleted = false\nGROUP BY sm.company_name\nORDER BY total_bookings DESC;", "rows_returned": 5, "truncated": false, "execution_time_ms": 2.51, "query_index": 5}
