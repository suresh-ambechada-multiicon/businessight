{"timestamp": "2026-05-05 12:21:03,703", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "70caa861f06c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    sm.company_name,\n    COUNT(DISTINCT ib.id) as total_bookings,\n    SUM(CASE WHEN ibs.is_cancelled = 1 THEN 1 ELSE 0 END) as cancelled_bookings,\n    SUM(ibs.base_price + ibs.tax) as total_revenue,\n    (SELECT COUNT(*) FROM asego_insurance_plan_master WHERE supplier_id = sm.id AND is_deleted = 0) as active_plans\nFROM supplier_master sm\nLEFT JOIN insurance_booking ib ON sm.id = ib.supplier_id\nLEFT JOIN insurance_booking_sub ibs ON ib.id = ibs.insurance_booking_id\nWHERE sm.id IN (77, 4338)\nGROUP BY sm.company_name, sm.id", "rows_returned": 2, "truncated": false, "execution_time_ms": 89.61, "query_index": 3}
{"timestamp": "2026-05-05 12:21:06,073", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "70caa861f06c", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 10 * FROM asego_insurance_plan_master", "rows_returned": 10, "truncated": false, "execution_time_ms": 10.91, "query_index": 4}
