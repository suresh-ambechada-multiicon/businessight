{"timestamp": "2026-05-02 06:15:54,804", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "7216410a0152", "session_id": "1777701555404", "client_ip": "127.0.0.1", "model": "google_genai:gemini-2.5-flash", "db_uri_hash": "34fd0c4055f9", "query": "SELECT COUNT(DISTINCT ab.id) AS total_bookings, SUM(ap.basefare + ap.tax + ap.service_charge + ap.service_charge_gst) AS total_revenue FROM air_booking ab JOIN air_pax ap ON ab.id = ap.air_booking_id WHERE ab.is_deleted = FALSE;", "rows_returned": 1, "truncated": false, "execution_time_ms": 323.93, "query_index": 1}
{"timestamp": "2026-05-02 06:15:58,511", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "7216410a0152", "session_id": "1777701555404", "client_ip": "127.0.0.1", "model": "google_genai:gemini-2.5-flash", "db_uri_hash": "34fd0c4055f9", "query": "SELECT alm.airline_name, COUNT(DISTINCT ab.id) AS total_bookings, SUM(ap.basefare + ap.tax + ap.service_charge + ap.service_charge_gst) AS total_revenue FROM air_booking ab JOIN air_pax ap ON ab.id = ap.air_booking_id JOIN air_segment ase ON ab.id = ase.air_booking_id JOIN airline_master alm ON ase.airline_code = alm.short_code WHERE ab.is_deleted = FALSE AND ase.is_deleted = FALSE GROUP BY alm.airline_name ORDER BY total_revenue DESC LIMIT 100;", "rows_returned": 100, "truncated": false, "execution_time_ms": 304.34, "query_index": 2}
