{"timestamp": "2026-05-06 20:33:51,139", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "60c580c3398f", "session_id": "1778099330173", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    ROUND(SUM(CASE WHEN ab.status = 'Confirmed' THEN 1 ELSE 0 END) * 100.0 / COUNT(*), 2) AS success_rate_pct\nFROM (\n    SELECT supplier_id, booking_status AS status, entry_date_time FROM air_booking\n    UNION ALL\n    SELECT supplier_id, booking_status AS status, entry_date_time FROM hotel_booking\n    UNION ALL\n    SELECT supplier_id, status, entry_date_time FROM bus_booking\n) ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= '2024-04-16'\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 20;", "rows_returned": 20, "truncated": false, "execution_time_ms": 62.78, "query_index": 2}
