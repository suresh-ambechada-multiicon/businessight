{"timestamp": "2026-05-04 09:14:58,886", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "88b3633a7e84", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT fail_reason, count(*) as count\nFROM (\n    SELECT fail_reason FROM air_booking WHERE booking_status IN ('Booking Failed', 'Payment Failed', 'Failed')\n    UNION ALL\n    SELECT fail_reason FROM hotel_booking WHERE booking_status IN ('Booking Failed', 'Payment Failed', 'Failed')\n    UNION ALL\n    SELECT fail_reason FROM insurance_booking WHERE booking_status IN ('Booking Failed', 'Payment Failed', 'Failed')\n) as failures\nWHERE fail_reason IS NOT NULL AND fail_reason != ''\nGROUP BY fail_reason\nORDER BY count DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 60.94, "query_index": 4}
{"timestamp": "2026-05-04 09:15:02,647", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "88b3633a7e84", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    type,\n    count(*) as count\nFROM (\n    SELECT 'Air' as type, booking_status as status FROM air_booking\n    UNION ALL\n    SELECT 'Bus' as type, status as status FROM bus_booking\n    UNION ALL\n    SELECT 'Hotel' as type, booking_status as status FROM hotel_booking\n    UNION ALL\n    SELECT 'Insurance' as type, booking_status as status FROM insurance_booking\n    UNION ALL\n    SELECT 'Visa' as type, visa_status as status FROM visa_booking\n    UNION ALL\n    SELECT 'Offline' as type, status as status FROM offline_service_booking\n    UNION ALL\n    SELECT 'Holiday' as type, lead_status as status FROM holiday_booking_leads\n) as combined\nWHERE status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'Inprocess', 'Applied', 'New', 'Confirmation Pending', 'Cancellation Pending', 'Hold', 'Documents Revised')\nGROUP BY type\nORDER BY count DESC;", "rows_returned": 7, "truncated": false, "execution_time_ms": 8.13, "query_index": 5}
{"timestamp": "2026-05-04 09:15:06,826", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "88b3633a7e84", "session_id": "1777886059110", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(entry_date_time, 'YYYY-MM') as month,\n    category,\n    count(*) as count\nFROM (\n    SELECT \n        entry_date_time,\n        CASE \n            WHEN booking_status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n            WHEN booking_status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed', 'Hold Released') THEN 'Failed'\n        END as category\n    FROM air_booking\n    UNION ALL\n    SELECT \n        entry_date_time,\n        CASE \n            WHEN status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n            WHEN status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed', 'Hold Released') THEN 'Failed'\n        END as category\n    FROM bus_booking\n    UNION ALL\n    SELECT \n        entry_date_time,\n        CASE \n            WHEN booking_status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n            WHEN booking_status IN ('Booking Failed', 'Payment Failed', 'Failed', 'Hold Failed', 'Hold Released') THEN 'Failed'\n        END as category\n    FROM hotel_booking\n) as combined\nWHERE category IS NOT NULL AND entry_date_time >= CURRENT_DATE - INTERVAL '6 months'\nGROUP BY month, category\nORDER BY month, category;", "rows_returned": 9, "truncated": false, "execution_time_ms": 32.83, "query_index": 6}
