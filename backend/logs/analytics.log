{"timestamp": "2026-05-02 06:53:34,446", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "9f367bc5d904", "session_id": "1777703767723", "client_ip": "127.0.0.1", "model": "google_genai:gemini-2.5-flash", "db_uri_hash": "34fd0c4055f9", "query": "SELECT\n  pfd.id AS flight_id,\n  cm_dep.city_name AS departure_city,\n  pfd.departure_date_time,\n  cm_arr.city_name AS arrival_city,\n  pfd.arrival_date_time,\n  pfd.trip_type,\n  pfd.cabin_baggage,\n  pfd.checkin_baggage\nFROM product_flight_details AS pfd\nJOIN city_master AS cm_dep\n  ON pfd.departure_city_id = cm_dep.id\nJOIN city_master AS cm_arr\n  ON pfd.arrival_city_id = cm_arr.id\nWHERE\n  cm_dep.city_name = 'Delhi' OR cm_arr.city_name = 'Delhi'\nLIMIT 100;", "rows_returned": 0, "truncated": false, "execution_time_ms": 8.61, "query_index": 4}
{"timestamp": "2026-05-02 06:54:05,378", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "9f367bc5d904", "session_id": "1777703767723", "client_ip": "127.0.0.1", "model": "google_genai:gemini-2.5-flash", "db_uri_hash": "34fd0c4055f9", "query": "SELECT\n  hqf.id AS flight_id,\n  am_dep.airport_name AS departure_airport,\n  am_dep.city AS departure_city,\n  hqf.departure_date_time,\n  am_arr.airport_name AS arrival_airport,\n  am_arr.city AS arrival_city,\n  hqf.arrival_date_time,\n  hqf.trip_type,\n  hqf.cabin_baggage,\n  hqf.checkin_baggage\nFROM holiday_quotation_flight AS hqf\nJOIN airport_mst AS am_dep\n  ON hqf.departure_city_id = am_dep.id\nJOIN airport_mst AS am_arr\n  ON hqf.arrival_city_id = am_arr.id\nWHERE\n  am_dep.city = 'Delhi' OR am_arr.city = 'Delhi'\nLIMIT 100;", "rows_returned": 0, "truncated": false, "execution_time_ms": 3.49, "query_index": 5}
