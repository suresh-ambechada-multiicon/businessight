{"timestamp": "2026-05-06 19:17:37,564", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "4ea251430286", "session_id": "1778094853768", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    'Air' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Hotel' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Bus' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN bb.status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM bus_booking bb\nJOIN supplier_master sm ON bb.supplier_id = sm.id\nWHERE bb.entry_date_time >= CURRENT_DATE - INTERVAL '3 months'\n  AND bb.is_deleted = false\nGROUP BY sm.company_name\n\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 3, "truncated": false, "execution_time_ms": 1.92, "query_index": 1}
{"timestamp": "2026-05-06 19:17:39,620", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "4ea251430286", "session_id": "1778094853768", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    MAX(entry_date_time) as latest_air,\n    MIN(entry_date_time) as earliest_air\nFROM air_booking;", "rows_returned": 1, "truncated": false, "execution_time_ms": 3.32, "query_index": 2}
{"timestamp": "2026-05-06 19:17:39,621", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "4ea251430286", "session_id": "1778094853768", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    MAX(entry_date_time) as latest_hotel,\n    MIN(entry_date_time) as earliest_hotel\nFROM hotel_booking;", "rows_returned": 1, "truncated": false, "execution_time_ms": 2.29, "query_index": 3}
{"timestamp": "2026-05-06 19:17:45,783", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "4ea251430286", "session_id": "1778094853768", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    'Air' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= (SELECT MAX(entry_date_time) FROM air_booking) - INTERVAL '3 months'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Hotel' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= (SELECT MAX(entry_date_time) FROM hotel_booking) - INTERVAL '3 months'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\n\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 5, "truncated": false, "execution_time_ms": 4.75, "query_index": 4}
{"timestamp": "2026-05-06 19:17:49,714", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "4ea251430286", "session_id": "1778094853768", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    'Air' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) * 100.0 / NULLIF(COUNT(*), 0) AS success_rate\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= (SELECT MAX(entry_date_time) FROM air_booking) - INTERVAL '3 months'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\n\nUNION ALL\n\nSELECT \n    sm.company_name AS supplier_name,\n    'Hotel' AS service_type,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN hb.booking_status = 'Confirmed' THEN 1 ELSE 0 END) * 100.0 / NULLIF(COUNT(*), 0) AS success_rate\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.entry_date_time >= (SELECT MAX(entry_date_time) FROM hotel_booking) - INTERVAL '3 months'\n  AND hb.is_deleted = false\nGROUP BY sm.company_name\n\nORDER BY total_bookings DESC;", "rows_returned": 5, "truncated": false, "execution_time_ms": 18.51, "query_index": 5}
{"timestamp": "2026-05-06 19:17:52,399", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "4ea251430286", "session_id": "1778094853768", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name AS supplier_name,\n    COUNT(*) AS total_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Confirmed' THEN 1 ELSE 0 END) AS confirmed_bookings,\n    SUM(CASE WHEN ab.booking_status = 'Payment Failed' THEN 1 ELSE 0 END) AS payment_failed,\n    SUM(CASE WHEN ab.booking_status NOT IN ('Confirmed', 'Payment Failed') THEN 1 ELSE 0 END) AS other_status\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.entry_date_time >= (SELECT MAX(entry_date_time) FROM air_booking) - INTERVAL '3 months'\n  AND ab.is_deleted = false\nGROUP BY sm.company_name\nORDER BY total_bookings DESC;", "rows_returned": 4, "truncated": false, "execution_time_ms": 1.99, "query_index": 6}
