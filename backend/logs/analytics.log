{"timestamp": "2026-05-04 13:29:21,961", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "95ae132c8138", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    (SELECT COUNT(*) FROM airline_master WHERE is_deleted = false) as total_airlines,\n    (SELECT COUNT(*) FROM air_booking WHERE is_deleted = false) as total_bookings,\n    (SELECT SUM(net_sale_amount) FROM booking_price WHERE booking_service IN ('Airline', 'Air Amendment') AND is_deleted = false) as total_revenue,\n    (SELECT COUNT(*) FROM air_booking WHERE booking_status = 'Confirmed' AND is_deleted = false) as confirmed_bookings\n", "rows_returned": 1, "truncated": false, "execution_time_ms": 178.88, "query_index": 2}
{"timestamp": "2026-05-04 13:29:24,603", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "95ae132c8138", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT am.airline_name, COUNT(ab.id) as booking_count\nFROM air_booking ab\nJOIN airline_master am ON ab.flight_id = am.short_code\nWHERE ab.is_deleted = false\nGROUP BY am.airline_name\nORDER BY booking_count DESC\nLIMIT 10", "rows_returned": 0, "truncated": false, "execution_time_ms": 147.45, "query_index": 3}
{"timestamp": "2026-05-04 13:29:27,048", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "95ae132c8138", "session_id": "1777895582766", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT * FROM air_booking LIMIT 5", "rows_returned": 5, "truncated": false, "execution_time_ms": 34.6, "query_index": 4}
