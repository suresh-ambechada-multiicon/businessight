{"timestamp": "2026-05-04 10:25:27,781", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "43ba3a052746", "session_id": "1777888598729", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    EXTRACT(YEAR FROM bp.entry_date_time) AS year, \n    cm.currency_short_code,\n    COUNT(*) AS total_bookings,\n    SUM(bp.total_markup) AS total_markup\nFROM booking_price bp\nJOIN currency_master cm ON bp.sale_currency_id = cm.id\nWHERE bp.is_deleted = false OR bp.is_deleted IS NULL\nGROUP BY year, cm.currency_short_code\nORDER BY year, total_markup DESC;", "rows_returned": 17, "truncated": false, "execution_time_ms": 263.25, "query_index": 3}
