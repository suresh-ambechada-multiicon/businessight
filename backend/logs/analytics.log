{"timestamp": "2026-05-05 11:42:05,755", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "7cb9ff5dc6d8", "session_id": "1777981293104", "client_ip": "127.0.0.1", "model": "google_genai:gemini-2.5-pro", "db_uri_hash": "322e42547825", "query": "SELECT\n    TOP 1000\n    sm.company_name AS provider_name,\n    SUM(b.booking_count) AS total_bookings\nFROM (\n    SELECT\n        supplier_id,\n        COUNT(id) AS booking_count\n    FROM air_booking\n    WHERE entry_date_time >= '2023-07-25'\n    GROUP BY supplier_id\n\n    UNION ALL\n\n    SELECT\n        supplier_id,\n        COUNT(id) AS booking_count\n    FROM hotel_booking\n    WHERE entry_date_time >= '2023-07-25'\n    GROUP BY supplier_id\n\n    UNION ALL\n\n    SELECT\n        supplier_id,\n        COUNT(id) AS booking_count\n    FROM bus_booking\n    WHERE entry_date_time >= '2023-07-25'\n    GROUP BY supplier_id\n) b\nJOIN supplier_master sm ON b.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC;", "rows_returned": 29, "truncated": false, "execution_time_ms": 1041.65, "query_index": 1}
