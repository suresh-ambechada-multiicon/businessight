{"timestamp": "2026-05-05 11:02:33,031", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d6b7a5276939", "session_id": "1777978810440", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 1000\n    s.company_name AS provider_name,\n    COUNT(ab.id) AS air_bookings,\n    COUNT(hb.id) AS hotel_bookings,\n    COUNT(bb.id) AS bus_bookings,\n    (COUNT(ab.id) + COUNT(hb.id) + COUNT(bb.id)) AS total_bookings\nFROM supplier_master s\nLEFT JOIN air_booking ab ON s.id = ab.supplier_id AND ab.entry_date_time >= DATEADD(year, -1, GETDATE())\nLEFT JOIN hotel_booking hb ON s.id = hb.supplier_id AND hb.entry_date_time >= DATEADD(year, -1, GETDATE())\nLEFT JOIN bus_booking bb ON s.id = bb.supplier_id AND bb.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY s.company_name\nHAVING (COUNT(ab.id) + COUNT(hb.id) + COUNT(bb.id)) > 0\nORDER BY total_bookings DESC", "rows_returned": 21, "truncated": false, "execution_time_ms": 1378.9, "query_index": 1}
{"timestamp": "2026-05-05 11:02:36,129", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d6b7a5276939", "session_id": "1777978810440", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 10\n    s.company_name AS provider_name,\n    (COUNT(ab.id) + COUNT(hb.id) + COUNT(bb.id)) AS total_bookings\nFROM supplier_master s\nLEFT JOIN air_booking ab ON s.id = ab.supplier_id AND ab.entry_date_time >= DATEADD(year, -1, GETDATE())\nLEFT JOIN hotel_booking hb ON s.id = hb.supplier_id AND hb.entry_date_time >= DATEADD(year, -1, GETDATE())\nLEFT JOIN bus_booking bb ON s.id = bb.supplier_id AND bb.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY s.company_name\nHAVING (COUNT(ab.id) + COUNT(hb.id) + COUNT(bb.id)) > 0\nORDER BY total_bookings DESC", "rows_returned": 10, "truncated": false, "execution_time_ms": 1183.84, "query_index": 2}
{"timestamp": "2026-05-05 11:02:39,132", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d6b7a5276939", "session_id": "1777978810440", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 20\n    s.company_name AS provider_name,\n    (COUNT(ab.id) + COUNT(hb.id) + COUNT(bb.id)) AS total_bookings\nFROM supplier_master s\nLEFT JOIN air_booking ab ON s.id = ab.supplier_id AND ab.entry_date_time >= DATEADD(year, -1, GETDATE())\nLEFT JOIN hotel_booking hb ON s.id = hb.supplier_id AND hb.entry_date_time >= DATEADD(year, -1, GETDATE())\nLEFT JOIN bus_booking bb ON s.id = bb.supplier_id AND bb.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY s.company_name\nHAVING (COUNT(ab.id) + COUNT(hb.id) + COUNT(bb.id)) > 0\nORDER BY total_bookings DESC", "rows_returned": 20, "truncated": false, "execution_time_ms": 1185.7, "query_index": 3}
