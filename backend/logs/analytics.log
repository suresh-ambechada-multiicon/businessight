{"timestamp": "2026-05-04 10:25:41,163", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "43ba3a052746", "session_id": "1777888598729", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT booking_service, sale_currency_id, total_markup, roe, net_sale_amount \nFROM booking_price \nWHERE total_markup > 0 \nLIMIT 5;", "rows_returned": 5, "truncated": false, "execution_time_ms": 1.22, "query_index": 6}
{"timestamp": "2026-05-04 10:25:43,519", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "43ba3a052746", "session_id": "1777888598729", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT booking_service, sale_currency_id, total_markup, roe, net_sale_amount \nFROM booking_price \nWHERE sale_currency_id = 14 AND total_markup > 0 \nLIMIT 5;", "rows_returned": 5, "truncated": false, "execution_time_ms": 3.94, "query_index": 7}
{"timestamp": "2026-05-04 10:25:48,518", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "43ba3a052746", "session_id": "1777888598729", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    EXTRACT(YEAR FROM bp.entry_date_time) AS year,\n    SUM(CASE \n        WHEN bp.sale_currency_id = 1 THEN bp.total_markup\n        WHEN bp.sale_currency_id = 14 THEN bp.total_markup * 24.9566\n        WHEN bp.sale_currency_id = 3 THEN bp.total_markup * 91.6564\n        WHEN bp.sale_currency_id = 25 THEN bp.total_markup * 24.4408\n        WHEN bp.sale_currency_id = 31 THEN bp.total_markup * 0.0651\n        WHEN bp.sale_currency_id = 32 THEN bp.total_markup * 243.7579\n        WHEN bp.sale_currency_id = 33 THEN bp.total_markup * 25.1794\n        ELSE bp.total_markup \n    END) AS total_markup_inr,\n    COUNT(*) AS total_bookings\nFROM booking_price bp\nWHERE bp.is_deleted = false OR bp.is_deleted IS NULL\nGROUP BY year\nORDER BY year;", "rows_returned": 3, "truncated": false, "execution_time_ms": 272.37, "query_index": 8}
{"timestamp": "2026-05-04 10:25:52,776", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "43ba3a052746", "session_id": "1777888598729", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    EXTRACT(MONTH FROM bp.entry_date_time) AS month,\n    SUM(CASE \n        WHEN bp.sale_currency_id = 1 THEN bp.total_markup\n        WHEN bp.sale_currency_id = 14 THEN bp.total_markup * 24.9566\n        WHEN bp.sale_currency_id = 3 THEN bp.total_markup * 91.6564\n        WHEN bp.sale_currency_id = 25 THEN bp.total_markup * 24.4408\n        WHEN bp.sale_currency_id = 31 THEN bp.total_markup * 0.0651\n        WHEN bp.sale_currency_id = 32 THEN bp.total_markup * 243.7579\n        WHEN bp.sale_currency_id = 33 THEN bp.total_markup * 25.1794\n        ELSE bp.total_markup \n    END) AS total_markup_inr,\n    COUNT(*) AS total_bookings\nFROM booking_price bp\nWHERE (bp.is_deleted = false OR bp.is_deleted IS NULL)\n  AND EXTRACT(YEAR FROM bp.entry_date_time) = 2025\nGROUP BY month\nORDER BY month;", "rows_returned": 12, "truncated": false, "execution_time_ms": 120.73, "query_index": 9}
