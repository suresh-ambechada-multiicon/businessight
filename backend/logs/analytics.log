{"timestamp": "2026-05-04 09:11:19,839", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "da318f555723", "session_id": "1777885854538", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    type,\n    CASE \n        WHEN status IN ('Confirmed', 'Success', 'Completed', 'Payment Completed', 'Payment Confirmed') THEN 'Confirmed'\n        WHEN status IN ('Cancelled', 'Partially Cancelled', 'Partial Cancelled', 'Rejected', 'Documents Rejected') THEN 'Cancelled'\n        WHEN status IN ('Pending', 'Waiting for Payment', 'Waiting For Payment', 'Inprocess', 'Applied', 'Confirmation Pending', 'Hold', 'New', 'Partial Payment Completed', 'Documents Revised', 'Hold Released', 'Cancellation Pending') THEN 'Pending'\n        WHEN status IN ('Refunded', 'Assign To Refund') THEN 'Refunded'\n        WHEN status IN ('Payment Failed', 'Booking Failed', 'Failed', 'Hold Failed') THEN 'Failed'\n        ELSE 'Other'\n    END as category,\n    count(*) as count\nFROM (\n    SELECT 'Air' as type, booking_status as status FROM air_booking\n    UNION ALL\n    SELECT 'Bus' as type, status as status FROM bus_booking\n    UNION ALL\n    SELECT 'Hotel' as type, booking_status as status FROM hotel_booking\n    UNION ALL\n    SELECT 'Insurance' as type, booking_status as status FROM insurance_booking\n    UNION ALL\n    SELECT 'Visa' as type, visa_status as status FROM visa_booking\n    UNION ALL\n    SELECT 'Offline' as type, status as status FROM offline_service_booking\n) as combined\nGROUP BY type, category\nORDER BY type, count DESC;", "rows_returned": 26, "truncated": false, "execution_time_ms": 30.15, "query_index": 3}
