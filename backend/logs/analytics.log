{"timestamp": "2026-05-06 20:19:11,838", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d9a98d77bf0c", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT supplier_id FROM air_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT supplier_id FROM hotel_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT supplier_id FROM bus_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND status = 'Confirmed'\n) b\nJOIN supplier_master sm ON b.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 19, "truncated": false, "execution_time_ms": 61.4, "query_index": 1}
{"timestamp": "2026-05-06 20:19:15,109", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d9a98d77bf0c", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(CASE WHEN service = 'Air' THEN 1 END) as air_bookings,\n    COUNT(CASE WHEN service = 'Hotel' THEN 1 END) as hotel_bookings,\n    COUNT(CASE WHEN service = 'Bus' THEN 1 END) as bus_bookings,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT supplier_id, 'Air' as service FROM air_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT supplier_id, 'Hotel' as service FROM hotel_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT supplier_id, 'Bus' as service FROM bus_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND status = 'Confirmed'\n) b\nJOIN supplier_master sm ON b.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 1000;", "rows_returned": 19, "truncated": false, "execution_time_ms": 42.85, "query_index": 2}
{"timestamp": "2026-05-06 20:19:17,777", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d9a98d77bf0c", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    TO_CHAR(entry_date_time, 'YYYY-MM') as month,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT entry_date_time FROM air_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT entry_date_time FROM hotel_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT entry_date_time FROM bus_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND status = 'Confirmed'\n) b\nGROUP BY 1\nORDER BY 1;", "rows_returned": 11, "truncated": false, "execution_time_ms": 37.87, "query_index": 3}
{"timestamp": "2026-05-06 20:19:20,656", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d9a98d77bf0c", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    sm.company_name as supplier_name,\n    COUNT(CASE WHEN b.service = 'Air' THEN 1 END) as air_bookings,\n    COUNT(CASE WHEN b.service = 'Hotel' THEN 1 END) as hotel_bookings,\n    COUNT(CASE WHEN b.service = 'Bus' THEN 1 END) as bus_bookings,\n    COUNT(*) as total_bookings\nFROM (\n    SELECT supplier_id, 'Air' as service FROM air_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT supplier_id, 'Hotel' as service FROM hotel_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\n    UNION ALL\n    SELECT supplier_id, 'Bus' as service FROM bus_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND status = 'Confirmed'\n) b\nJOIN supplier_master sm ON b.supplier_id = sm.id\nGROUP BY sm.company_name\nORDER BY total_bookings DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 29.55, "query_index": 4}
{"timestamp": "2026-05-06 20:19:23,120", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "d9a98d77bf0c", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT \n    'Air' as service, COUNT(*) as count FROM air_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\nUNION ALL\nSELECT \n    'Hotel' as service, COUNT(*) as count FROM hotel_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND booking_status = 'Confirmed'\nUNION ALL\nSELECT \n    'Bus' as service, COUNT(*) as count FROM bus_booking WHERE entry_date_time >= CURRENT_DATE - INTERVAL '1 year' AND status = 'Confirmed';", "rows_returned": 3, "truncated": false, "execution_time_ms": 25.11, "query_index": 5}
