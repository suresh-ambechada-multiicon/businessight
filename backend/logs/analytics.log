{"timestamp": "2026-05-05 11:18:56,156", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "10dce906c76b", "session_id": "1777979924546", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    s.company_name,\n    COUNT(ab.id) AS total_bookings\nFROM supplier_master s\nLEFT JOIN air_booking ab ON s.id = ab.supplier_id AND ab.entry_date_time >= DATEADD(year, -1, GETDATE())\nGROUP BY s.company_name\nORDER BY total_bookings DESC\nOFFSET 0 ROWS FETCH NEXT 1000 ROWS ONLY;", "rows_returned": 775, "truncated": false, "execution_time_ms": 946.66, "query_index": 1}
{"timestamp": "2026-05-05 11:18:59,214", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "10dce906c76b", "session_id": "1777979924546", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    s.company_name,\n    SUM(booking_count) AS total_bookings\nFROM (\n    SELECT supplier_id, COUNT(*) AS booking_count FROM air_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM hotel_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM bus_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM insurance_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n) AS all_bookings\nJOIN supplier_master s ON all_bookings.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_bookings DESC\nOFFSET 0 ROWS FETCH NEXT 1000 ROWS ONLY;", "rows_returned": 23, "truncated": false, "execution_time_ms": 1020.37, "query_index": 2}
{"timestamp": "2026-05-05 11:19:01,929", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "10dce906c76b", "session_id": "1777979924546", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3.1-flash-lite-preview", "db_uri_hash": "322e42547825", "query": "SELECT TOP 15\n    s.company_name,\n    SUM(booking_count) AS total_bookings\nFROM (\n    SELECT supplier_id, COUNT(*) AS booking_count FROM air_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM hotel_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM bus_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n    UNION ALL\n    SELECT supplier_id, COUNT(*) AS booking_count FROM insurance_booking WHERE entry_date_time >= DATEADD(year, -1, GETDATE()) GROUP BY supplier_id\n) AS all_bookings\nJOIN supplier_master s ON all_bookings.supplier_id = s.id\nGROUP BY s.company_name\nORDER BY total_bookings DESC;", "rows_returned": 15, "truncated": false, "execution_time_ms": 1081.02, "query_index": 3}
