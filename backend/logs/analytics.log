{"timestamp": "2026-05-05 12:23:50,124", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "600464f74754", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    sm.company_name,\n    COUNT(ib.id) as total_bookings,\n    SUM(CASE WHEN ib.booking_status IN ('Cancelled', 'PartiallyCancelled') THEN 1 ELSE 0 END) as cancelled_bookings,\n    SUM(bp.net_sale_amount) as total_sale_amount,\n    SUM(bp.net_purchase) as total_purchase_amount\nFROM supplier_master sm\nLEFT JOIN insurance_booking ib ON sm.id = ib.supplier_id\nLEFT JOIN booking_price bp ON ib.id = bp.booking_id AND bp.booking_service = 'Insurance'\nWHERE sm.id IN (77, 4338)\nGROUP BY sm.company_name", "rows_returned": 2, "truncated": false, "execution_time_ms": 536.98, "query_index": 2}
{"timestamp": "2026-05-05 12:23:52,741", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "600464f74754", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    sm.company_name,\n    ipm.plan_name,\n    COUNT(ib.id) as booking_count,\n    SUM(bp.net_sale_amount) as sale_amount\nFROM supplier_master sm\nJOIN insurance_booking ib ON sm.id = ib.supplier_id\nJOIN asego_insurance_plan_master ipm ON ib.plan_id = ipm.id\nJOIN booking_price bp ON ib.id = bp.booking_id AND bp.booking_service = 'Insurance'\nWHERE sm.id IN (77, 4338)\nGROUP BY sm.company_name, ipm.plan_name\nORDER BY booking_count DESC\nOFFSET 0 ROWS FETCH NEXT 10 ROWS ONLY", "rows_returned": 10, "truncated": false, "execution_time_ms": 117.08, "query_index": 3}
{"timestamp": "2026-05-05 12:23:55,186", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "600464f74754", "session_id": "1777981920379", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "322e42547825", "query": "SELECT \n    FORMAT(entry_date_time, 'yyyy-MM') as booking_month,\n    COUNT(id) as monthly_bookings,\n    SUM(CASE WHEN booking_status IN ('Cancelled', 'PartiallyCancelled') THEN 1 ELSE 0 END) as monthly_cancellations\nFROM insurance_booking\nWHERE supplier_id IN (77, 4338)\nGROUP BY FORMAT(entry_date_time, 'yyyy-MM')\nORDER BY booking_month DESC\nOFFSET 0 ROWS FETCH NEXT 12 ROWS ONLY", "rows_returned": 12, "truncated": false, "execution_time_ms": 56.96, "query_index": 4}
