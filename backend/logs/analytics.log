{"timestamp": "2026-05-06 20:24:35,506", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "8727ba7ed947", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT sm.company_name, COUNT(*) as count\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.booking_status = 'Confirmed' AND ab.entry_date_time >= CURRENT_DATE - INTERVAL '18 months'\nGROUP BY sm.company_name\nORDER BY count DESC\nLIMIT 10;", "rows_returned": 10, "truncated": false, "execution_time_ms": 125.66, "query_index": 1}
{"timestamp": "2026-05-06 20:24:39,186", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "8727ba7ed947", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT sm.company_name, 'Air' as service, COUNT(*) as count\nFROM air_booking ab\nJOIN supplier_master sm ON ab.supplier_id = sm.id\nWHERE ab.booking_status = 'Confirmed' AND ab.entry_date_time >= CURRENT_DATE - INTERVAL '18 months'\nGROUP BY sm.company_name\nUNION ALL\nSELECT sm.company_name, 'Bus' as service, COUNT(*) as count\nFROM bus_booking bb\nJOIN supplier_master sm ON bb.supplier_id = sm.id\nWHERE bb.status = 'Confirmed' AND bb.entry_date_time >= CURRENT_DATE - INTERVAL '18 months'\nGROUP BY sm.company_name\nUNION ALL\nSELECT sm.company_name, 'Hotel' as service, COUNT(*) as count\nFROM hotel_booking hb\nJOIN supplier_master sm ON hb.supplier_id = sm.id\nWHERE hb.booking_status = 'Confirmed' AND hb.entry_date_time >= CURRENT_DATE - INTERVAL '18 months'\nGROUP BY sm.company_name\nORDER BY count DESC;", "rows_returned": 19, "truncated": false, "execution_time_ms": 143.45, "query_index": 2}
{"timestamp": "2026-05-06 20:24:42,201", "level": "INFO", "logger": "analytics.tools", "message": "SQL executed", "request_id": "8727ba7ed947", "session_id": "1778098731949", "client_ip": "127.0.0.1", "model": "google_genai:gemini-3-flash-preview", "db_uri_hash": "34fd0c4055f9", "query": "SELECT TO_CHAR(entry_date_time, 'YYYY-MM') as month, COUNT(*) as count\nFROM (\n    SELECT entry_date_time FROM air_booking WHERE booking_status = 'Confirmed' AND entry_date_time >= CURRENT_DATE - INTERVAL '18 months'\n    UNION ALL\n    SELECT entry_date_time FROM bus_booking WHERE status = 'Confirmed' AND entry_date_time >= CURRENT_DATE - INTERVAL '18 months'\n    UNION ALL\n    SELECT entry_date_time FROM hotel_booking WHERE booking_status = 'Confirmed' AND entry_date_time >= CURRENT_DATE - INTERVAL '18 months'\n) as combined\nGROUP BY month\nORDER BY month ASC;", "rows_returned": 17, "truncated": false, "execution_time_ms": 69.66, "query_index": 3}
